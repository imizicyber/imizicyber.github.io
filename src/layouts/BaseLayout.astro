---
/**
 * BaseLayout — root layout for all pages.
 */
import '../styles/global.css';
import SEOHead from '../components/SEOHead.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import SkipLink from '../components/SkipLink.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import CookieBanner from '../components/CookieBanner.astro';
import { SITE } from '../data/site';

interface Props {
  title: string;
  description: string;
  keywords?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogType?: string;
  canonicalUrl: string;
  ogImage?: string;
  twitterTitle?: string;
  twitterDescription?: string;
  robots?: string;
  schemas?: Record<string, unknown>[];

  showWhatsApp?: boolean;
  whatsappMessage?: string;
  navVariant?: 'home' | 'inner';
  footerVariant?: 'home' | 'inner';
  showFreeTool?: boolean;
}

const {
  title,
  description,
  keywords,
  ogTitle,
  ogDescription,
  ogType,
  canonicalUrl,
  ogImage,
  twitterTitle,
  twitterDescription,
  robots,
  schemas,

  showWhatsApp = true,
  whatsappMessage,
  navVariant = 'inner',
  footerVariant = 'inner',
  showFreeTool = true,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <SEOHead
      title={title}
      description={description}
      keywords={keywords}
      ogTitle={ogTitle}
      ogDescription={ogDescription}
      ogType={ogType}
      canonicalUrl={canonicalUrl}
      ogImage={ogImage}
      twitterTitle={twitterTitle}
      twitterDescription={twitterDescription}
      robots={robots}
    />

    <meta name="theme-color" content="#0b1421" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="192x192" href="/logo-192.png" />
    <link rel="manifest" href="/manifest.json" />

    <meta name="dns-prefetch" content="//formspree.io" />
    <meta property="og:site_name" content={SITE.name} />

    <link
      rel="preload"
      href="/fonts/plus-jakarta-sans-400-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- CSP meta tag injected at build time by scripts/inject-csp.mjs -->

    {schemas && schemas.length > 0 && <SchemaOrg schemas={schemas} />}

    <!--
      QUAL-08 justified exception: This script MUST remain is:inline to prevent
      FOUC (Flash of Unstyled Content). It reads the user's theme preference from
      localStorage and applies it before the browser's first paint. Moving this
      to a module script would cause a visible flash as the default theme renders
      before the script executes.
    -->
    <script is:inline>
      (function () {
        try {
          const s = localStorage.getItem('imizi-theme');
          if (s) document.documentElement.dataset.theme = s;
        } catch {
          /* localStorage unavailable */
        }
      })();
    </script>
  </head>
  <body>
    <SkipLink />
    <header>
      <Nav variant={navVariant} showFreeTool={showFreeTool} />
    </header>

    <main id="main" role="main">
      <slot />
    </main>

    <Footer variant={footerVariant} />
    {showWhatsApp && <WhatsAppFloat prefilledText={whatsappMessage} />}
    <CookieBanner />

    <script>
      import { trackEvent } from '@/scripts/analytics';

      const CTA_SELECTOR = 'a[href*="contact"], a[href*="consultation"], .cta-btn, .hero-cta';

      document.body.addEventListener('click', (e) => {
        const target = (e.target as Element).closest?.(CTA_SELECTOR);
        if (target) {
          trackEvent('cta_click', {
            cta_text: target.textContent?.trim() || '',
            page: window.location.pathname,
          });
        }
      });
    </script>
  </body>
</html>
