---
/**
 * ContactForm — AJAX contact form with Formspree submission.
 */
import { ANALYTICS } from '../data/site';
---

<div class="form-box">
  <h3>Request a consultation</h3>
  <form id="contact-form">
    <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
    <div class="form-row">
      <div class="field">
        <label for="contact-name">Name</label><input
          type="text"
          name="name"
          id="contact-name"
          placeholder="Full name"
          required
        />
      </div>
      <div class="field">
        <label for="contact-email">Work email</label><input
          type="email"
          name="email"
          id="contact-email"
          required
        />
      </div>
    </div>
    <div class="form-row">
      <div class="field">
        <label for="contact-org">Organisation</label><input
          type="text"
          name="org"
          id="contact-org"
          placeholder="Company name"
        />
      </div>
      <div class="field">
        <label for="contact-service">Interest</label>
        <select name="service" id="contact-service" required>
          <option value="" disabled selected>Select a service</option>
          <option>Managed Security</option>
          <option>Penetration Testing</option>
          <option>Security Training</option>
          <option>BNR Compliance</option>
          <option>Custom Security Tooling</option>
          <option>Other</option>
        </select>
      </div>
    </div>
    <div class="field">
      <label for="contact-message">Details</label><textarea
        name="message"
        id="contact-message"
        placeholder="What do you need secured?"></textarea>
    </div>
    <button type="submit" class="submit-btn">Send enquiry</button>
    <div
      id="contact-success"
      style="display:none;margin-top:12px;padding:12px;background:rgba(52,211,153,.1);border:1px solid var(--acc);border-radius:8px;color:var(--acc);font-size:.85rem;font-weight:600"
    >
      Thank you! We will get back to you within 24 hours.
    </div>
    <div
      id="contact-error"
      style="display:none;margin-top:12px;padding:12px;background:rgba(239,68,68,.1);border:1px solid #ef4444;border-radius:8px;color:#ef4444;font-size:.85rem"
    >
      Something went wrong. Please try again or contact us via WhatsApp.
    </div>
  </form>
</div>

<script define:vars={{ formspreeUrl: ANALYTICS.formspreeUrl }}>
  document.getElementById('contact-form').addEventListener('submit', function (e) {
    e.preventDefault();
    const form = e.currentTarget;
    const btn = form.querySelector('.submit-btn');
    const ok = document.getElementById('contact-success');
    const err = document.getElementById('contact-error');
    ok.style.display = 'none';
    err.style.display = 'none';
    btn.textContent = 'Sending...';
    btn.disabled = true;
    fetch(formspreeUrl, {
      method: 'POST',
      body: new FormData(form),
      headers: { Accept: 'application/json' },
    })
      .then(function (r) {
        if (r.ok) {
          ok.style.display = 'block';
          form.reset();
          btn.textContent = 'Sent!';
        } else {
          err.style.display = 'block';
          btn.textContent = 'Send enquiry';
          btn.disabled = false;
        }
      })
      .catch(function () {
        err.style.display = 'block';
        btn.textContent = 'Send enquiry';
        btn.disabled = false;
      });
  });
</script>
