---
/**
 * TagFilter — client-side tag filter buttons for the blog index.
 * Progressive enhancement: all posts visible by default without JS.
 * @prop tags - array of unique tag strings from all blog posts
 */
interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

<div class="tag-filter">
  <button class="tag-btn active" data-tag="all">All</button>
  {
    tags.map((tag) => (
      <button class="tag-btn" data-tag={tag}>
        {tag}
      </button>
    ))
  }
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    const buttons = document.querySelectorAll<HTMLButtonElement>('.tag-btn');
    const cards = document.querySelectorAll<HTMLElement>('.blog-card-wrapper');

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const tag = btn.dataset.tag;

        // Update active state
        buttons.forEach((b) => b.classList.remove('active'));
        btn.classList.add('active');

        // Filter cards
        cards.forEach((card) => {
          if (tag === 'all') {
            card.style.display = '';
          } else {
            const cardTags = (card.dataset.tags || '').split(',');
            card.style.display = cardTags.includes(tag ?? '') ? '' : 'none';
          }
        });
      });
    });
  });
</script>

<style>
  .tag-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 24px;
  }
  .tag-btn {
    border-radius: 20px;
    padding: 6px 16px;
    font-size: 0.78rem;
    font-family: var(--mono);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    cursor: pointer;
    transition:
      background 0.2s,
      color 0.2s;
    background: var(--card);
    color: var(--txt2);
    border: 1px solid var(--border);
  }
  .tag-btn.active {
    background: var(--acc);
    color: var(--bg);
    border-color: var(--acc);
  }
  .tag-btn:hover:not(.active) {
    color: var(--white);
    border-color: var(--txt2);
  }
</style>
