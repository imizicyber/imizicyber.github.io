---
/**
 * SchemaOrg — renders JSON-LD structured data blocks.
 * @prop schemas - array of schema objects to render
 */
interface Props {
  schemas: Record<string, unknown>[];
}

const { schemas } = Astro.props;
---

{schemas.map((schema) => <script type="application/ld+json" set:html={JSON.stringify(schema)} />)}
