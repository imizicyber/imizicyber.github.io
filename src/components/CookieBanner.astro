---
/**
 * CookieBanner — cookie consent banner with GA loading.
 */
---

<div class="cookie-banner" id="cookie-banner" role="dialog" aria-modal="true" aria-label="Cookie consent" aria-describedby="cookie-msg">
  <p id="cookie-msg">We use cookies for analytics to improve our website. No tracking cookies are set without your consent. <a href="/privacy-policy/">Privacy Policy</a></p>
  <div class="cookie-btns">
    <button class="btn-reject" id="cookie-reject">Reject</button>
    <button class="btn-accept" id="cookie-accept">Accept</button>
  </div>
</div>

<script>
  import { initCookieBanner } from '@/scripts/cookie-consent';
  initCookieBanner();
</script>
