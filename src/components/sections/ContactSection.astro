---
/**
 * ContactSection -- Contact form and info.
 */
import ContactForm from '@/components/ContactForm.astro';
import { CONTACT, SITE } from '@/data/site';
---

<section id="contact" class="sec" aria-label="Contact us">
  <div class="w reveal">
    <div class="sec-tag">CONTACT</div>
    <h2 class="sec-title">Get in touch</h2>
    <p class="sec-sub">We respond within 24 hours.</p>
    <div class="contact-grid">
      <div>
        <div class="contact-info">
          <div class="contact-label">Email</div>
          <a class="contact-val" id="email-link" href="mailto:info@imizicyber.com">Loading...</a>
        </div>
        <div class="contact-info">
          <div class="contact-label">Phone</div>
          <a class="contact-val" href="tel:+250793146617">{CONTACT.phone}</a>
        </div>
        <div class="contact-info">
          <div class="contact-label">Location</div>
          <span class="contact-val">Kigali, Rwanda</span>
        </div>
        <div class="contact-info">
          <div class="contact-label">Entity</div>
          <span class="contact-val">{SITE.legalName}</span>
        </div>
        <a href={CONTACT.whatsappUrl} class="contact-wa" target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24"
            ><path
              d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"
            ></path><path
              d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.5.5 0 00.611.611l4.458-1.495A11.952 11.952 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.75c-2.16 0-4.16-.696-5.788-1.876l-.404-.3-2.645.886.886-2.645-.3-.404A9.724 9.724 0 012.25 12C2.25 6.615 6.615 2.25 12 2.25S21.75 6.615 21.75 12 17.385 21.75 12 21.75z"
            ></path></svg
          >
          WhatsApp for immediate response
        </a>
      </div>
      <ContactForm />
    </div>
  </div>
</section>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 24px;
  }
  .contact-info {
    margin-bottom: 12px;
  }
  .contact-label {
    font-size: 0.64rem;
    color: var(--txt3);
    font-weight: 400;
    margin-bottom: 1px;
  }
  .contact-val {
    font-size: 0.86rem;
    color: var(--white);
    font-weight: 700;
    text-decoration: none;
    display: block;
  }
  a.contact-val:hover {
    color: var(--acc);
  }
  .contact-wa {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #1b7a42;
    color: #fff;
    padding: 8px 16px;
    border-radius: 6px;
    font-size: 0.78rem;
    font-weight: 700;
    text-decoration: none;
    margin-top: 8px;
    transition: background 0.2s;
  }
  .contact-wa:hover {
    background: #166e3a;
  }
  .contact-wa svg {
    width: 16px;
    height: 16px;
    fill: #fff;
  }

  /* LIGHT THEME OVERRIDES */
  [data-theme='light'] .contact-wa {
    color: #fff;
  }

  /* RESPONSIVE - MOBILE */
  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
