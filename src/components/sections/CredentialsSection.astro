---
import { CREDENTIALS } from '../../data/credentials';
---

<section id="about" class="sec sec-b">
  <div class="w reveal">
    <div class="sec-tag">ABOUT</div>
    <h2 class="sec-title">Independent offensive security consultancy, based in Kigali</h2>
    <p class="sec-sub">
      imizicyber is a registered Rwandan offensive security firm serving banks, government agencies,
      and enterprises across East Africa and South Africa. We combine hands-on penetration testing
      with managed security tooling deployment.
    </p>

    <div class="stats-row">
      <div class="stat"><strong>6+</strong><span>Countries served</span></div>
      <div class="stat"><strong>50+</strong><span>Security engagements</span></div>
      <div class="stat"><strong>5+</strong><span>Years offensive security</span></div>
      <div class="stat"><strong>500+</strong><span>Professionals trained</span></div>
    </div>

    <div class="cred-label">CREDENTIALS</div>
    <div class="cred-grid">
      {
        CREDENTIALS.map((cred) => (
          <div class="cred-card">
            <div class="cred-badge">{cred.badge}</div>
            <div class="cred-info">
              <b>{cred.title}</b>
              <span>{cred.org}</span>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 8px;
    margin-bottom: 24px;
  }
  .stat {
    padding: 16px;
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: 10px;
    background: var(--bg2);
  }
  .stat strong {
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--acc);
    display: block;
    letter-spacing: -0.5px;
  }
  .stat span {
    font-size: 0.68rem;
    color: var(--txt3);
  }
  .cred-label {
    font-family: var(--mono);
    font-size: 0.62rem;
    font-weight: 500;
    color: var(--txt3);
    letter-spacing: 0.1em;
    margin-bottom: 10px;
  }
  .cred-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
  }
  .cred-card {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 14px;
    background: var(--bg2);
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: 8px;
    transition: border-color 0.2s;
  }
  .cred-card:hover {
    border-color: rgba(52, 211, 153, 0.15);
  }
  .cred-badge {
    font-family: var(--mono);
    font-size: 0.56rem;
    font-weight: 700;
    color: var(--acc);
    background: rgba(52, 211, 153, 0.08);
    padding: 6px 8px;
    border-radius: 5px;
    letter-spacing: 0.04em;
    flex-shrink: 0;
    min-width: 36px;
    text-align: center;
  }
  .cred-info {
    display: flex;
    flex-direction: column;
  }
  .cred-info b {
    font-size: 0.78rem;
    font-weight: 800;
    color: var(--white);
    line-height: 1.3;
  }
  .cred-info span {
    font-size: 0.66rem;
    color: var(--txt3);
    line-height: 1.3;
  }

  /* LIGHT THEME OVERRIDES */
  [data-theme='light'] .stat {
    border-color: rgba(0, 0, 0, 0.08);
  }
  [data-theme='light'] .cred-card {
    border-color: rgba(0, 0, 0, 0.08);
  }

  /* RESPONSIVE - TABLET */
  @media (max-width: 1024px) {
    .cred-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  /* RESPONSIVE - MOBILE */
  @media (max-width: 768px) {
    .stats-row {
      grid-template-columns: 1fr 1fr;
    }
    .cred-grid {
      grid-template-columns: 1fr;
    }
  }

  /* RESPONSIVE - SMALL */
  @media (max-width: 480px) {
    .stats-row {
      grid-template-columns: 1fr;
    }
    .stat {
      padding: 12px;
    }
  }
</style>
