---
/**
 * Nav component — fixed navigation bar.
 * @prop variant - 'home' uses anchor links, 'inner' uses absolute paths
 * @prop showFreeTool - show the "Free Score" CTA button (default false)
 */
import Logo from './Logo.astro';
import ThemeToggle from './ThemeToggle.astro';

interface Props {
  variant?: 'home' | 'inner';
  showFreeTool?: boolean;
}

const { variant = 'inner', showFreeTool = false } = Astro.props;
const isHome = variant === 'home';

const servicesHref = isHome ? '#services' : '/#services';
const blogHref = isHome ? '#blog' : '/blog/';
const contactHref = isHome ? '#contact' : '/#contact';
---

<nav>
  <div class="w">
    <div class="nav-inner">
      <a href="/" class="logo">
        <Logo />
        <span class="logo-text"><b>imizi</b>cyber</span>
      </a>
      <div class="nav-links">
        <a href={servicesHref}>Services</a>
        <a href={blogHref}>Blog</a>
        <a href="/resources/">Resources</a>
        <a href={contactHref}>Contact</a>
        {showFreeTool && (
          <a href="/tools/security-score/" class="nav-cta" style="background:transparent;border:1.5px solid var(--acc);color:var(--acc) !important">Free Score</a>
        )}
        <a href={contactHref} class="nav-cta">Get in Touch</a>
      </div>
      <div class="nav-end">
        <ThemeToggle />
        <button class="menu-btn" aria-label="Menu" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
  </div>
</nav>

<script>
  (function(){
    var btn = document.querySelector('.menu-btn');
    var nav = document.querySelector('.nav-links');
    if(btn && nav){
      btn.addEventListener('click', function(){
        nav.classList.toggle('open');
        btn.classList.toggle('active');
        btn.setAttribute('aria-expanded', nav.classList.contains('open').toString());
      });
      nav.querySelectorAll('a').forEach(function(a){
        a.addEventListener('click', function(){
          nav.classList.remove('open');
          btn.classList.remove('active');
          btn.setAttribute('aria-expanded', 'false');
        });
      });
    }
  })();
</script>
