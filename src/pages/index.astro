---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import { SITE, CONTACT } from '../data/site';

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': ['ProfessionalService', 'LocalBusiness'],
    '@id': `${SITE.url}/#organization`,
    name: 'imizicyber',
    legalName: SITE.legalName,
    description:
      'OSCP-certified offensive security consultancy in Kigali, Rwanda. Penetration testing, red team operations, managed security services, and compliance assessments for banks and regulated organisations across East Africa and South Africa.',
    url: SITE.url,
    logo: `${SITE.url}/logo-192.png`,
    image: `${SITE.url}/og.png`,
    foundingDate: '2026-01-27',
    telephone: '+250793146617',
    priceRange: '$$',
    currenciesAccepted: 'RWF, USD, EUR',
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'Norrsken House',
      addressLocality: 'Kigali',
      addressCountry: 'RW',
    },
    geo: { '@type': 'GeoCoordinates', latitude: -1.9403, longitude: 29.8739 },
    areaServed: [
      { '@type': 'Country', name: 'Rwanda' },
      { '@type': 'Country', name: 'Kenya' },
      { '@type': 'Country', name: 'Uganda' },
      { '@type': 'Country', name: 'Tanzania' },
      { '@type': 'Country', name: 'South Africa' },
      { '@type': 'Place', name: 'East Africa' },
      { '@type': 'Place', name: 'Southern Africa' },
    ],
    founder: {
      '@type': 'Person',
      name: 'Aristofanis Chionis',
      jobTitle: 'Founder & Lead Penetration Tester',
      url: 'https://www.linkedin.com/in/aristofanischionis/',
      hasCredential: [
        {
          '@type': 'EducationalOccupationalCredential',
          name: 'OSCP - Offensive Security Certified Professional',
        },
        {
          '@type': 'EducationalOccupationalCredential',
          name: 'OSCP+ - Offensive Security Certified Professional Plus',
        },
        {
          '@type': 'EducationalOccupationalCredential',
          name: 'PNPT - Practical Network Penetration Tester',
        },
      ],
    },
    knowsAbout: [
      'Offensive Security',
      'Penetration Testing',
      'Red Team Operations',
      'BNR Cybersecurity Regulation',
      'PCI DSS',
      'ISO 27001',
      'OSCP',
      'OWASP',
      'Web Application Security',
      'Mobile Banking Security',
      'API Security Testing',
      'Vulnerability Assessment',
      'VAPT',
      'Security Audit',
    ],
    hasOfferCatalog: {
      '@type': 'OfferCatalog',
      name: 'Cybersecurity Services',
      itemListElement: [
        {
          '@type': 'Offer',
          itemOffered: {
            '@type': 'Service',
            name: 'Penetration Testing',
            description:
              'Network, web application, API, and mobile application penetration testing to identify exploitable vulnerabilities.',
          },
        },
        {
          '@type': 'Offer',
          itemOffered: {
            '@type': 'Service',
            name: 'Managed Security Services',
            description:
              'Ongoing security monitoring and incident response for organizations requiring continuous protection.',
          },
        },
        {
          '@type': 'Offer',
          itemOffered: {
            '@type': 'Service',
            name: 'BNR Compliance Assessment',
            description:
              'Security assessments aligned with BNR regulations for banks, microfinance, and insurance companies in Rwanda.',
          },
        },
        {
          '@type': 'Offer',
          itemOffered: {
            '@type': 'Service',
            name: 'Mobile Banking & USSD Security Testing',
            description:
              'Specialized security testing for mobile money platforms, USSD services, and fintech applications.',
          },
        },
        {
          '@type': 'Offer',
          itemOffered: {
            '@type': 'Service',
            name: 'Security Training',
            description:
              'Security awareness and secure coding training programs for IT teams and organizations.',
          },
        },
      ],
    },
    sameAs: ['https://www.linkedin.com/in/aristofanischionis/'],
    parentOrganization: { '@type': 'Organization', name: SITE.legalName },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'Why do banks in Rwanda need penetration testing?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'BNR requires regulated financial institutions to maintain cybersecurity programs. Penetration testing finds vulnerabilities before attackers do and is a core component of BNR compliance.',
        },
      },
      {
        '@type': 'Question',
        name: 'Does imizicyber help with BNR cybersecurity compliance?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes. We help banks, microfinance institutions, and insurance companies meet BNR requirements through penetration testing, vulnerability assessments, and managed security.',
        },
      },
      {
        '@type': 'Question',
        name: 'What certifications do imizicyber consultants hold?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'OSCP and OSCP+, PNPT, and BlackHat Europe Arsenal presenter. Physically based in Kigali, Rwanda.',
        },
      },
      {
        '@type': 'Question',
        name: 'How much does penetration testing cost in Rwanda?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Costs vary by scope and complexity. Every engagement is scoped individually based on the number of applications, infrastructure complexity, and testing depth. Contact us for a tailored quote within 48 hours.',
        },
      },
      {
        '@type': 'Question',
        name: 'What is BNR Regulation on cybersecurity?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'The National Bank of Rwanda requires all regulated financial institutions to implement cybersecurity programs including regular vulnerability assessments, penetration testing, incident response plans, and security awareness training.',
        },
      },
      {
        '@type': 'Question',
        name: 'How often should banks do penetration testing?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'BNR recommends at minimum annual penetration testing, and after any significant infrastructure or application changes. Most institutions we work with test quarterly for critical systems.',
        },
      },
      {
        '@type': 'Question',
        name: 'What is the difference between VAPT and penetration testing?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'VAPT combines automated vulnerability scanning with manual penetration testing. Vulnerability assessment identifies weaknesses using tools. Penetration testing goes further by manually exploiting vulnerabilities to demonstrate real business impact.',
        },
      },
      {
        '@type': 'Question',
        name: 'Do I need ISO 27001 certification in Rwanda?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'ISO 27001 is not legally mandatory in Rwanda but is increasingly required by international partners, investors, and clients. BNR encourages ISO 27001 alignment for financial institutions. We help organisations prepare for certification through gap analysis and security improvements.',
        },
      },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'imizicyber',
    url: SITE.url,
    description:
      'Offensive security, penetration testing, and managed cybersecurity services in Kigali, Rwanda, East Africa, and South Africa',
    publisher: { '@type': 'Organization', name: 'imizicyber', '@id': `${SITE.url}/#organization` },
  },
];

const blogPosts = [
  {
    href: '/blog/bank-fraud-east-africa-cybersecurity-lessons/',
    date: 'MAR 2026',
    read: '8 MIN READ',
    title:
      'A major bank in Rwanda was hit by fraud. Here is what every institution should do next.',
    desc: 'A recent fraud incident exposed gaps in vendor security, mobile money controls, and transaction monitoring that exist across the entire East African banking sector. Five things to review this week.',
    featured: true,
  },
  {
    href: '/blog/penetration-testing-rwanda/',
    date: 'MAR 2026',
    read: '15 MIN READ',
    title: 'Penetration testing in Rwanda: the complete guide (2026)',
    desc: 'Everything you need to know about penetration testing in Rwanda: who needs it, what it covers, how to choose a provider, and what it costs.',
  },
  {
    href: '/blog/bnr-cybersecurity-requirements/',
    date: 'FEB 2026',
    read: '12 MIN READ',
    title: 'BNR cybersecurity requirements: what banks in Rwanda need to know',
    desc: "A practical breakdown of the National Bank of Rwanda's cybersecurity regulation and what it means for your institution's security program.",
  },
  {
    href: '/blog/east-africa-cybersecurity/',
    date: 'MAR 2026',
    read: '14 MIN READ',
    title: 'Cybersecurity in East Africa: threats, regulations, and protection (2026)',
    desc: 'The current cybersecurity landscape across Rwanda, Kenya, Uganda, and Tanzania: key threats, national regulations, and how organisations can protect themselves.',
  },
  {
    href: '/blog/penetration-testing-cost-rwanda/',
    date: 'FEB 2026',
    read: '10 MIN READ',
    title: 'How much does penetration testing cost in Rwanda?',
    desc: 'What drives penetration testing costs in Rwanda: scope, methodology, and certification level, and how to evaluate proposals correctly.',
  },
  {
    href: '/blog/mobile-money-security-testing/',
    date: 'MAR 2026',
    read: '11 MIN READ',
    title: 'Mobile money security testing: MoMo, M-Pesa, and USSD platforms',
    desc: 'How attackers target mobile money platforms in East Africa and what a professional security assessment of MoMo, M-Pesa, and USSD services looks like.',
  },
  {
    href: '/blog/api-security-banking/',
    date: 'MAR 2026',
    read: '10 MIN READ',
    title: 'API security in modern banking: common vulnerabilities we find',
    desc: 'The most frequently exploited API vulnerabilities in banking platforms, from IDOR and broken authentication to mass assignment and business logic flaws.',
  },
  {
    href: '/blog/data-breach-cost-east-africa/',
    date: 'MAR 2026',
    read: '12 MIN READ',
    title: 'The real cost of a data breach for East African banks',
    desc: 'What a data breach actually costs banks in Rwanda and East Africa: regulatory fines, customer loss, legal liability, and the hidden costs most organisations miss.',
  },
  {
    href: '/blog/social-engineering-east-africa-banks/',
    date: 'MAR 2026',
    read: '11 MIN READ',
    title: 'Social engineering threats facing East African financial institutions',
    desc: 'How social engineering attacks target banks and fintechs in East Africa, and the practical defences that actually work against phishing, vishing, and pretexting.',
  },
];

const faqItems = [
  {
    q: 'Why do banks in Rwanda need penetration testing?',
    a: 'BNR requires regulated financial institutions to maintain cybersecurity programs. Penetration testing finds vulnerabilities in your web apps, mobile banking, APIs, and USSD services before attackers do. It is a core component of BNR compliance.',
  },
  {
    q: 'Do you help with BNR cybersecurity compliance?',
    a: 'Yes. We help banks, microfinance institutions, and insurance companies meet BNR cybersecurity requirements through penetration testing, vulnerability assessments, security audits, and ongoing managed security.',
  },
  {
    q: 'How much does penetration testing cost in Rwanda?',
    a: 'Every engagement is scoped individually based on the number of applications, infrastructure complexity, and testing depth. Contact us with your requirements and we will provide a detailed quote within 48 hours.',
  },
  {
    q: 'What is BNR Regulation on cybersecurity?',
    a: 'The National Bank of Rwanda requires all regulated financial institutions to implement cybersecurity programs including regular vulnerability assessments, penetration testing, incident response plans, and security awareness training. We help organisations meet these requirements.',
  },
  {
    q: 'What certifications do your consultants hold?',
    a: 'OSCP and OSCP+ (the gold standard in penetration testing), PNPT, and BlackHat Europe Arsenal presenter. Physically based in Kigali, Rwanda.',
  },
  {
    q: 'How often should banks do penetration testing?',
    a: 'BNR recommends at minimum annual penetration testing, and after any significant infrastructure or application changes. Most institutions we work with test quarterly for critical systems like mobile banking and payment APIs.',
  },
  {
    q: 'What is the difference between VAPT and penetration testing?',
    a: 'VAPT combines automated vulnerability scanning with manual penetration testing. Vulnerability assessment identifies weaknesses using tools. Penetration testing goes further by manually exploiting vulnerabilities to demonstrate real business impact. We do both.',
  },
  {
    q: 'Do I need ISO 27001 certification in Rwanda?',
    a: 'ISO 27001 is not legally mandatory in Rwanda but is increasingly required by international partners, investors, and clients. BNR encourages ISO 27001 alignment for financial institutions. We help organisations prepare through gap analysis and security improvements.',
  },
  {
    q: 'Do you offer cybersecurity training for employees?',
    a: 'Yes. We deliver security awareness training for all staff levels, from executive briefings to hands-on technical workshops for developers and IT teams. Training covers phishing recognition, secure coding practices, incident response procedures, and BNR compliance requirements. Available on-site in Kigali or remotely across East Africa.',
  },
  {
    q: 'Do you work with organisations outside Rwanda?',
    a: 'Yes. We are based in Kigali but deliver engagements across East Africa, including remote assessments. Our lead consultant has worked in offensive security roles in Denmark and the UAE, and has delivered penetration testing engagements in multiple African countries.',
  },
];
---

<BaseLayout
  title="Penetration Testing & Offensive Security Kigali | imizicyber"
  description="OSCP-certified offensive security consultancy in Kigali. Penetration testing and managed security for banks across East Africa and South Africa."
  keywords="offensive security Kigali, penetration testing Rwanda, pentest East Africa, penetration testing South Africa, cybersecurity Kigali, offensive security East Africa, managed security services Rwanda, BNR cybersecurity compliance, VAPT Rwanda, security audit East Africa, OSCP penetration tester Kigali, pentest Kigali, red team East Africa, API security testing, mobile app security Rwanda, ISO 27001 Rwanda, PCI DSS compliance Rwanda, cybersecurity consultant Kigali, mobile money security Rwanda, USSD security testing, mobile banking penetration test, fintech security Rwanda, offensive security South Africa, penetration testing cost Rwanda, VAPT certification Rwanda, pentest South Africa"
  ogTitle="Penetration Testing & Offensive Security Kigali | imizicyber"
  ogDescription="OSCP-certified offensive security consultancy in Kigali. Penetration testing and managed security for banks across East Africa and South Africa."
  twitterTitle="Penetration Testing & Offensive Security Kigali | imizicyber"
  twitterDescription="OSCP-certified penetration testing and managed security in Kigali, Rwanda"
  canonicalUrl={`${SITE.url}/`}
  schemas={schemas}
  navVariant="home"
  footerVariant="home"
  showFreeTool={true}
>
  <main id="main">
    <!-- HERO -->
    <section class="hero">
      <div class="w">
        <div class="tag">KIGALI, RWANDA</div>
        <h1>Offensive security and penetration testing for <em>regulated organisations</em></h1>
        <p class="hero-sub">
          OSCP-certified. Built for banks, telecoms, and government agencies across East Africa and
          South Africa.
        </p>
        <div class="btns">
          <a href="#contact" class="btn btn-fill">Request a consultation</a>
          <a
            href={CONTACT.whatsappUrl}
            class="btn btn-wa"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg viewBox="0 0 24 24"
              ><path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"
              ></path><path
                d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.5.5 0 00.611.611l4.458-1.495A11.952 11.952 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.75c-2.16 0-4.16-.696-5.788-1.876l-.404-.3-2.645.886.886-2.645-.3-.404A9.724 9.724 0 012.25 12C2.25 6.615 6.615 2.25 12 2.25S21.75 6.615 21.75 12 17.385 21.75 12 21.75z"
              ></path></svg
            >
            WhatsApp us
          </a>
          <a href="#services" class="btn btn-ghost">Our services</a>
        </div>
        <div class="hero-terminal">
          <div class="terminal-bar">
            <span class="terminal-dot"></span>
            <span class="terminal-dot"></span>
            <span class="terminal-dot"></span>
            <span class="terminal-title">imizicyber - security assessment</span>
          </div>
          <div class="terminal-body">
            <div class="terminal-line">
              <span class="prompt">$ </span><span class="cmd">imizicyber</span>
              <span class="flag">--scan</span>
              <span class="cmd">webapp api mobile</span>
            </div>
            <div class="terminal-line">
              <span class="result">[+] 3 targets queued - manual testing mode</span>
            </div>
            <div class="terminal-line"><span class="result">[+] OSCP methodology loaded</span></div>
            <div class="terminal-line">
              <span class="prompt">$ </span><span class="cmd">report</span>
              <span class="flag">--format</span>
              <span class="cmd">executive</span>
              <span class="flag">--compliance</span>
              <span class="cmd">bnr pci iso27001</span>
            </div>
            <div class="terminal-line">
              <span class="result">[+] Report generated - 14 findings, 3 critical</span>
            </div>
            <div class="terminal-line">
              <span class="prompt">$ </span><span class="terminal-cursor"></span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- TRUST -->
    <div class="trust">
      <div class="w">
        <div class="trust-stats">
          <div class="trust-stat"><strong>6+</strong><span>countries</span></div>
          <span class="trust-sep">&bull;</span>
          <div class="trust-stat"><strong>50+</strong><span>engagements</span></div>
          <span class="trust-sep">&bull;</span>
          <div class="trust-stat"><strong>OSCP</strong><span>certified</span></div>
          <span class="trust-sep">&bull;</span>
          <div class="trust-stat"><strong>BlackHat</strong><span>Europe presenter</span></div>
        </div>
      </div>
    </div>

    <!-- WHY US -->
    <section class="why">
      <div class="w reveal">
        <h2 class="sr-only">Why choose imizicyber</h2>
        <div class="why-grid">
          <div class="why-item">
            <div class="why-icon">
              <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"
                ><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><polyline
                  points="9 12 11 14 15 10"></polyline></svg
              >
            </div>
            <div class="why-num">01</div>
            <h3>OSCP-certified, in Kigali</h3>
            <p>
              OSCP and OSCP+ certified penetration tester physically based in Rwanda. Not remote
              contractors, not scanner output.
            </p>
          </div>
          <div class="why-item">
            <div class="why-icon">
              <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"
                ><rect x="2" y="4" width="20" height="16" rx="2"></rect><polyline
                  points="6 10 10 14 6 18"></polyline><line x1="14" y1="18" x2="18" y2="18"
                ></line></svg
              >
            </div>
            <div class="why-num">02</div>
            <h3>We build custom tooling</h3>
            <p>
              Security validation tools in Python, Go, and JavaScript tailored to your specific APIs
              and systems.
            </p>
          </div>
          <div class="why-item">
            <div class="why-icon">
              <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"
                ><polygon points="12 2 2 7 2 10 22 10 22 7 12 2"></polygon><line
                  x1="6"
                  y1="10"
                  x2="6"
                  y2="18"></line><line x1="10" y1="10" x2="10" y2="18"></line><line
                  x1="14"
                  y1="10"
                  x2="14"
                  y2="18"></line><line x1="18" y1="10" x2="18" y2="18"></line><rect
                  x="2"
                  y="18"
                  width="20"
                  height="2"></rect></svg
              >
            </div>
            <div class="why-num">03</div>
            <h3>Banking red team experience</h3>
            <p>
              Our consultants come from threat-led red team operations at European banks protecting
              millions of customers.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- SERVICES -->
    <section id="services" class="sec sec-b">
      <div class="w reveal">
        <div class="sec-tag">SERVICES</div>
        <h2 class="sec-title">Three ways to work with us</h2>
        <p class="sec-sub">Ongoing protection, targeted assessments, or training for your team.</p>
        <div class="cards">
          <a href="/services/managed-security/" class="card">
            <div class="card-tag">MANAGED / MONTHLY RETAINER</div>
            <h3>Continuous Security</h3>
            <p>
              We deploy and manage security tooling across your environment and deliver monthly
              reports. An outsourced security function without the headcount.
            </p>
            <div class="pills">
              <span>SAST/DAST in CI/CD</span>
              <span>Attack surface monitoring</span>
              <span>Vulnerability tracking</span>
              <span>Custom validation tools</span>
              <span>Monthly reporting</span>
              <span>Incident support</span>
            </div>
            <span class="card-cta">View managed security &#8594;</span>
          </a>
          <a href="/services/penetration-testing/" class="card">
            <div class="card-tag">ON-DEMAND / PER ENGAGEMENT</div>
            <h3>Penetration Testing</h3>
            <p>
              Manual security assessments by an OSCP-certified consultant. For compliance, product
              launches, or regulatory sign-off.
            </p>
            <div class="pills">
              <span>Web apps and APIs</span>
              <span>Mobile banking</span>
              <span>USSD services</span>
              <span>Network and Wi-Fi</span>
              <span>IoT and cameras</span>
              <span>Desktop / thick clients</span>
              <span>BNR / PCI DSS / ISO 27001</span>
            </div>
            <span class="card-cta">View penetration testing &#8594;</span>
          </a>
          <a href="/services/security-training/" class="card">
            <div class="card-tag">TRAINING / ON-SITE OR REMOTE</div>
            <h3>Security Awareness Training</h3>
            <p>
              Hands-on cybersecurity training for employees and IT teams. From executive awareness
              to technical workshops for developers and security staff.
            </p>
            <div class="pills">
              <span>Employee awareness</span>
              <span>Phishing simulations</span>
              <span>Secure coding</span>
              <span>Incident response drills</span>
              <span>Board-level briefings</span>
              <span>BNR compliance training</span>
            </div>
            <span class="card-cta">View security training &#8594;</span>
          </a>
        </div>
      </div>
    </section>

    <!-- PROCESS -->
    <section id="process" class="sec sec-b">
      <div class="w reveal">
        <div class="sec-tag">PROCESS</div>
        <h2 class="sec-title">How we work</h2>
        <p class="sec-sub">From scoping to remediation, we keep it straightforward.</p>
        <div class="process">
          <div class="step">
            <div class="step-num">1</div>
            <div class="step-line"></div>
            <h4>Scoping call</h4>
            <p>We understand your environment, compliance needs, and testing objectives</p>
          </div>
          <div class="step">
            <div class="step-num">2</div>
            <div class="step-line"></div>
            <h4>Proposal and SOW</h4>
            <p>Clear scope, timeline, cost, and rules of engagement within 48 hours</p>
          </div>
          <div class="step">
            <div class="step-num">3</div>
            <div class="step-line"></div>
            <h4>Testing</h4>
            <p>1-3 weeks of manual testing with daily status updates on critical findings</p>
          </div>
          <div class="step">
            <div class="step-num">4</div>
            <div class="step-line"></div>
            <h4>Report and support</h4>
            <p>Detailed report with remediation guidance and 30 days of free follow-up</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ABOUT -->
    <section id="about" class="sec sec-b">
      <div class="w reveal">
        <div class="sec-tag">ABOUT</div>
        <h2 class="sec-title">Independent offensive security consultancy, based in Kigali</h2>
        <p class="sec-sub">
          imizicyber is a registered Rwandan offensive security firm serving banks, government
          agencies, and enterprises across East Africa and South Africa. We combine hands-on
          penetration testing with managed security tooling deployment.
        </p>

        <div class="stats-row">
          <div class="stat"><strong>6+</strong><span>Countries served</span></div>
          <div class="stat"><strong>50+</strong><span>Security engagements</span></div>
          <div class="stat"><strong>5+</strong><span>Years offensive security</span></div>
          <div class="stat"><strong>500+</strong><span>Professionals trained</span></div>
        </div>

