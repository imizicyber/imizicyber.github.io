---
/**
 * Company Profile - standalone print-optimised page.
 * Does NOT use BaseLayout; has its own minimal layout for PDF/print output.
 */
import { SITE, CONTACT } from '../../data/site';
import '../../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Company Profile - {SITE.legalName}</title>
    <meta name="robots" content="noindex, nofollow" />
    <link
      rel="preload"
      href="/fonts/plus-jakarta-sans-400-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link rel="icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="192x192" href="/logo-192.png" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#0b1421" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to main content</a>

    <div class="print-bar no-print">
      <span
        >Save as PDF: click the button, then select <b>"Save as PDF"</b> as destination. Use <b
          >A4</b
        >, no margins.</span
      >
      <button id="print-btn">Save as PDF</button>
    </div>
    <div class="screen-spacer no-print"></div>

    <!-- PAGE 1 -->
    <div class="page" id="main">
      <div class="hero">
        <div class="hero-top">
          <div class="header-left">
            <div class="header-logo">
              <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                <title>imizicyber logo</title>
                <circle cx="50" cy="12" r="5" fill="#34d399" opacity="0.7"></circle>
                <line
                  x1="50"
                  y1="18"
                  x2="50"
                  y2="52"
                  stroke="#34d399"
                  stroke-width="4.5"
                  stroke-linecap="round"></line>
                <line
                  x1="50"
                  y1="52"
                  x2="24"
                  y2="82"
                  stroke="#34d399"
                  stroke-width="4"
                  stroke-linecap="round"></line>
                <line
                  x1="50"
                  y1="52"
                  x2="50"
                  y2="88"
                  stroke="#34d399"
                  stroke-width="4"
                  stroke-linecap="round"
                  opacity="0.5"></line>
                <line
                  x1="50"
                  y1="52"
                  x2="76"
                  y2="82"
                  stroke="#34d399"
                  stroke-width="4"
                  stroke-linecap="round"></line>
                <circle cx="24" cy="82" r="3.5" fill="#34d399" opacity="0.45"></circle>
                <circle cx="50" cy="88" r="3.5" fill="#34d399" opacity="0.3"></circle>
                <circle cx="76" cy="82" r="3.5" fill="#34d399" opacity="0.45"></circle>
              </svg>
            </div>
            <div class="header-wordmark"><b>imizi</b><span>cyber</span></div>
          </div>
          <div class="header-right">Company Profile</div>
        </div>
        <div class="hero-content">
          <h1 class="company-name">{SITE.legalName}</h1>
          <div class="company-desc">
            Offensive security consultancy protecting banks, telecoms, and regulated organisations
            across East Africa. Penetration testing, managed security, and security awareness
            training delivered by experienced professionals on the ground in Kigali.
          </div>
          <div class="company-loc">{CONTACT.address}</div>
        </div>
        <div class="stats">
          <div class="stat-box">
            <span class="stat-num">6+</span><span class="stat-label">Countries served</span>
          </div>
          <div class="stat-box">
            <span class="stat-num">50+</span><span class="stat-label">Security engagements</span>
          </div>
          <div class="stat-box">
            <span class="stat-num">5+</span><span class="stat-label">Years offensive security</span>
          </div>
          <div class="stat-box">
            <span class="stat-num">500+</span><span class="stat-label">Professionals trained</span>
          </div>
        </div>
      </div>
      <div class="hero-accent"></div>

      <div class="section-content">
        <div class="label">Leadership</div>
        <div class="team">
          <div class="team-member">
            <div class="team-name">Aristofanis Chionis Koufakos</div>
            <div class="team-title">Founder &amp; Lead Penetration Tester</div>
            <div class="team-text">
              Software engineer turned offensive security specialist. BSc from NKUA Athens, MSc
              Computer Security from DTU Denmark. Red team and penetration testing at major banks
              across Europe, Africa, and the Middle East. Builds custom security tooling for
              clients.
            </div>
            <div class="team-tags">
              <span class="tag tag-primary">OSCP &amp; OSCP+</span>
              <span class="tag tag-primary">PNPT</span>
              <span class="tag">BlackHat Europe</span>
              <span class="tag">MSc Computer Security</span>
              <span class="tag">BSc Computer Science</span>
            </div>
          </div>
          <div class="team-member">
            <div class="team-name">Evalyne Kembabazi</div>
            <div class="team-title">Marketing &amp; Business Development</div>
            <div class="team-text">
              Client relationship experience from Qatar's hospitality and international sports
              industries. Manages partner networks, drives market expansion across East Africa, and
              ensures seamless engagement delivery.
            </div>
            <div class="team-tags">
              <span class="tag">Client Relations</span>
              <span class="tag">Partnerships</span>
              <span class="tag">Market Strategy</span>
              <span class="tag">East Africa</span>
            </div>
          </div>
        </div>

        <div class="callout">
          OSCP-certified and physically based in Kigali. Hands-on manual testing by an experienced
          professional on the ground, not remote contractors or automated scanner output.
        </div>

        <div class="label">Banking &amp; Financial Sector Experience</div>
        <h2 class="section-heading-sm">
          Trusted by institutions that handle millions of transactions daily
        </h2>
        <div class="exp-grid">
          <div class="exp-item">
            <div class="exp-name">Tier-1 Nordic Bank</div>
            <div class="exp-loc">Denmark</div>
            <div class="exp-desc">
              Internal red team member and penetration tester. Built CTF challenges and led employee
              security awareness programmes.
            </div>
          </div>
          <div class="exp-item">
            <div class="exp-name">Pan-African Banking Group</div>
            <div class="exp-loc">Multiple African countries</div>
            <div class="exp-desc">
              Penetration testing of web applications, APIs, core banking infrastructure, physical
              security systems, and VoIP platform hardening reviews.
            </div>
          </div>
          <div class="exp-item">
            <div class="exp-name">Top-5 South African Bank</div>
            <div class="exp-loc">South Africa</div>
            <div class="exp-desc">
              Built a custom penetration testing suite for critical API gateway infrastructure.
            </div>
          </div>
          <div class="exp-item">
            <div class="exp-name">Securities Trading Firm</div>
            <div class="exp-loc">Abu Dhabi, UAE</div>
            <div class="exp-desc">
              Penetration testing of the trading platform, targeting transaction workflows and
              financial data handling.
            </div>
          </div>
        </div>
      </div>

      <div class="page-footer">
        <span>imizicyber.com</span>

        <span>Page 1 of 2</span>
      </div>
    </div>

    <!-- PAGE 2 -->
    <div class="page">
      <div class="header">
        <div class="header-left">
          <div class="header-logo">
            <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
              <title>imizicyber logo</title>
              <circle cx="50" cy="12" r="5" fill="#34d399" opacity="0.7"></circle>
              <line
                x1="50"
                y1="18"
                x2="50"
                y2="52"
                stroke="#34d399"
                stroke-width="4.5"
                stroke-linecap="round"></line>
              <line
                x1="50"
                y1="52"
                x2="24"
                y2="82"
                stroke="#34d399"
                stroke-width="4"
                stroke-linecap="round"></line>
              <line
                x1="50"
                y1="52"
                x2="50"
                y2="88"
                stroke="#34d399"
                stroke-width="4"
                stroke-linecap="round"
                opacity="0.5"></line>
              <line
                x1="50"
                y1="52"
                x2="76"
                y2="82"
                stroke="#34d399"
                stroke-width="4"
                stroke-linecap="round"></line>
              <circle cx="24" cy="82" r="3.5" fill="#34d399" opacity="0.45"></circle>
              <circle cx="50" cy="88" r="3.5" fill="#34d399" opacity="0.3"></circle>
              <circle cx="76" cy="82" r="3.5" fill="#34d399" opacity="0.45"></circle>
            </svg>
          </div>
          <div class="header-wordmark"><b>imizi</b><span>cyber</span></div>
        </div>
        <div class="header-right">Services &amp; Process</div>
      </div>

      <div class="content-p2">
        <div class="label">Services</div>
        <h2 class="section-heading-lg">How We Help Regulated Organisations</h2>
        <div class="services">
          <div class="svc-card">
            <div class="svc-type">On-demand / Per engagement</div>
            <div class="svc-name">Penetration Testing</div>
            <ul class="svc-list">
              <li>Web applications &amp; APIs</li>
              <li>Mobile banking &amp; USSD</li>
              <li>Network &amp; infrastructure</li>
              <li>OS hardening reviews &amp; audits</li>
              <li>Social engineering &amp; red team</li>
              <li>Configuration &amp; compliance audits</li>
              <li>BNR-aligned reporting</li>
            </ul>
          </div>
          <div class="svc-card">
            <div class="svc-type">Managed / Monthly retainer</div>
            <div class="svc-name">Managed Security</div>
            <ul class="svc-list">
              <li>Vulnerability management</li>
              <li>Attack surface monitoring</li>
              <li>Custom security tooling development</li>
              <li>SAST/DAST in CI/CD pipelines</li>
              <li>Monthly executive reporting</li>
            </ul>
          </div>
          <div class="svc-card">
            <div class="svc-type">Training / On-site or remote</div>
            <div class="svc-name">Security Training</div>
            <ul class="svc-list">
              <li>Employee awareness programmes</li>
              <li>Phishing simulations</li>
              <li>Secure coding workshops</li>
              <li>Board-level briefings</li>
              <li>BNR compliance training</li>
            </ul>
          </div>
        </div>

        <div class="label">Testing Aligned With</div>
        <div class="compliance">
          <div class="comp-card">
            <div class="comp-badge">BNR</div>
            <div class="comp-name">
              Penetration testing that satisfies BNR cybersecurity regulation requirements for
              regulated institutions
            </div>
          </div>
          <div class="comp-card">
            <div class="comp-badge">OWASP</div>
            <div class="comp-name">
              Testing methodology aligned with OWASP Top 10 and OWASP ASVS standards
            </div>
          </div>
          <div class="comp-card">
            <div class="comp-badge">PTES</div>
            <div class="comp-name">
              Penetration Testing Execution Standard for structured, repeatable assessments
            </div>
          </div>
          <div class="comp-card">
            <div class="comp-badge">NIST</div>
            <div class="comp-name">
              Testing scoped to support NIST Cybersecurity Framework controls
            </div>
          </div>
        </div>

        <div class="label">Engagement Process</div>
        <div class="process">
          <div class="step">
            <div class="step-num">1</div>
            <div class="step-title">Scoping</div>
            <div class="step-desc">Understand your environment and compliance needs</div>
          </div>
          <div class="step">
            <div class="step-num">2</div>
            <div class="step-title">Proposal</div>
            <div class="step-desc">Clear scope, timeline, and cost within 48 hours</div>
          </div>
          <div class="step">
            <div class="step-num">3</div>
            <div class="step-title">Testing</div>
            <div class="step-desc">1-3 weeks manual testing with daily critical updates</div>
          </div>
          <div class="step">
            <div class="step-num">4</div>
            <div class="step-title">Report</div>
            <div class="step-desc">
              Detailed findings, live debrief, 1 free retest within 30 days
            </div>
          </div>
        </div>

        <div class="contact-block">
          <div class="contact-left">
            <h3>Ready to secure your organisation?</h3>
            <p>Let's discuss your security needs. We respond within 24 hours.</p>
          </div>
          <div class="contact-right">
            <div class="contact-item">
              <div class="contact-icon">
                <svg viewBox="0 0 24 24"
                  ><path
                    d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"
                  ></path></svg
                >
              </div>
              <div class="contact-text">{CONTACT.email}</div>
            </div>
            <div class="contact-item">
              <div class="contact-icon">
                <svg viewBox="0 0 24 24"
                  ><path
                    d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"
                  ></path></svg
                >
              </div>
              <div class="contact-text"><a href={SITE.url}>imizicyber.com</a></div>
            </div>
            <div class="contact-item">
              <div class="contact-icon">
                <svg viewBox="0 0 24 24"
                  ><path
                    d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1c0 1.25.2 2.46.57 3.58a1 1 0 01-.24 1.01l-2.21 2.2z"
                  ></path></svg
                >
              </div>
              <div class="contact-text">+250 793 146 617 (Aristos)</div>
            </div>
            <div class="contact-item">
              <div class="contact-icon">
                <svg viewBox="0 0 24 24"
                  ><path
                    d="M19 3a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h14m-.5 15.5v-5.3a3.26 3.26 0 00-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 011.4 1.4v4.93h2.79M6.88 8.56a1.68 1.68 0 001.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 00-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"
                  ></path></svg
                >
              </div>
              <div class="contact-text">
                <a href="https://www.linkedin.com/company/imizicyber"
                  >linkedin.com/company/imizicyber</a
                >
              </div>
            </div>
            <div class="contact-item">
              <div class="contact-icon">
                <svg viewBox="0 0 24 24"
                  ><path
                    d="M6.62 10.79a15.05 15.05 0 006.59 6.59l2.2-2.2a1 1 0 011.01-.24c1.12.37 2.33.57 3.58.57a1 1 0 011 1V20a1 1 0 01-1 1A17 17 0 013 4a1 1 0 011-1h3.5a1 1 0 011 1c0 1.25.2 2.46.57 3.58a1 1 0 01-.24 1.01l-2.21 2.2z"
                  ></path></svg
                >
              </div>
              <div class="contact-text">+250 793 146 577 (Eva)</div>
            </div>
            <div class="contact-item">
              <div class="contact-icon">
                <svg viewBox="0 0 24 24"
                  ><path
                    d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 010-5 2.5 2.5 0 010 5z"
                  ></path></svg
                >
              </div>
              <div class="contact-text">{CONTACT.address}</div>
            </div>
            <div class="contact-item">
              <div class="contact-icon">
                <svg viewBox="0 0 24 24"
                  ><path
                    d="M12 7V3H2v18h20V7H12zM6 19H4v-2h2v2zm0-4H4v-2h2v2zm0-4H4V9h2v2zm0-4H4V5h2v2zm4 12H8v-2h2v2zm0-4H8v-2h2v2zm0-4H8V9h2v2zm0-4H8V5h2v2zm10 12h-8v-2h2v-2h-2v-2h2v-2h-2V9h8v10zm-2-8h-2v2h2v-2zm0 4h-2v2h2v-2z"
                  ></path></svg
                >
              </div>
              <div class="contact-text">{SITE.legalName}</div>
            </div>
          </div>
        </div>
      </div>

      <div class="page-footer">
        <span>imizicyber.com</span>
        <span
          ><a href="/privacy-policy/" class="footer-link">Privacy Policy</a> &middot; <a
            href="/privacy-policy/"
            class="footer-link">Cookie Settings</a
          ></span
        >
        <span>Page 2 of 2</span>
      </div>
    </div>

    <!-- Cookie Consent Banner -->
    <div
      class="cookie-banner"
      id="cookie-banner"
      role="dialog"
      aria-modal="true"
      aria-label="Cookie consent"
      aria-describedby="cookie-msg"
    >
      <p id="cookie-msg">
        We use cookies for analytics to improve our website. No tracking cookies are set without
        your consent. <a href="/privacy-policy/">Privacy Policy</a>
      </p>
      <div class="cookie-btns">
        <button class="btn-reject" id="cookie-reject">Reject</button>
        <button class="btn-accept" id="cookie-accept">Accept</button>
      </div>
    </div>
    <script>
      import { initCookieBanner } from '@/scripts/cookie-consent';
      initCookieBanner();
      document.getElementById('print-btn')?.addEventListener('click', () => window.print());
    </script>
  </body>
</html>

<style>
  *,
  *::before,
  *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }
  :root {
    --navy: #0b1421;
    --navy2: #0f1b2d;
    --accent: #059669;
    --accent-light: #34d399;
    --txt: #2d3748;
    --txt2: #4a5568;
    --txt3: #718096;
    --border: #e2e8f0;
    --bg-card: rgba(52, 211, 153, 0.04);
    --white: #ffffff;
    --sans: 'Plus Jakarta Sans', system-ui, -apple-system, sans-serif;
    --mono: 'JetBrains Mono', ui-monospace, monospace;
  }

  .print-bar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--navy);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    padding: 12px 24px;
    font-family: var(--sans);
    font-size: 14px;
  }
  .print-bar button {
    background: var(--accent);
    color: #fff;
    border: none;
    padding: 8px 20px;
    border-radius: 6px;
    font-family: var(--sans);
    font-weight: 600;
    font-size: 14px;
    cursor: pointer;
  }
  .print-bar button:hover {
    background: #047857;
  }
  .screen-spacer {
    height: 52px;
  }

  body {
    background: #f0f0f0;
    font-family: var(--sans);
  }
  .page {
    width: 210mm;
    margin: 20px auto;
    background: var(--white);
    box-shadow: 0 4px 32px rgba(0, 0, 0, 0.08);
    position: relative;
    overflow: hidden;
    height: 297mm;
  }

  .section-content {
    padding: 14px 32px 0;
  }
  .section-heading-sm {
    font-size: 14px;
    font-weight: 800;
    color: var(--navy);
    margin-bottom: 8px;
    letter-spacing: -0.02em;
  }
  .section-heading-lg {
    font-size: 16px;
    font-weight: 800;
    color: var(--navy);
    margin-bottom: 10px;
    letter-spacing: -0.02em;
  }
  .footer-link {
    color: var(--txt3);
    text-decoration: none;
  }

  .hero {
    background: var(--navy);
    padding: 22px 32px 0;
    position: relative;
    overflow: hidden;
  }
  .hero-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
    position: relative;
    z-index: 1;
  }
  .header-left {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .header-logo svg {
    width: 28px;
    height: 28px;
  }
  .header-wordmark {
    font-size: 17px;
    letter-spacing: -0.02em;
  }
  .header-wordmark b {
    color: #f0f4f8;
    font-weight: 800;
  }
  .header-wordmark span {
    color: #8494a7;
    font-weight: 400;
  }
  .header-right {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.35);
    font-weight: 500;
  }
  .hero-content {
    position: relative;
    z-index: 1;
    margin-bottom: 16px;
  }
  .company-name {
    font-size: 28px;
    font-weight: 800;
    color: var(--white);
    margin-bottom: 6px;
    line-height: 1.1;
    letter-spacing: -0.03em;
  }
  .company-desc {
    font-size: 12.5px;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.55;
    max-width: 500px;
  }
  .company-loc {
    font-size: 10px;
    color: rgba(255, 255, 255, 0.3);
    margin-top: 5px;
    font-weight: 500;
    font-family: var(--mono);
    letter-spacing: 0.04em;
  }

  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    position: relative;
    z-index: 1;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: 12px;
    padding-bottom: 14px;
  }
  .stat-box {
    text-align: center;
    position: relative;
    padding: 0;
  }
  .stat-box + .stat-box::before {
    content: '';
    position: absolute;
    left: 0;
    top: 2px;
    bottom: 2px;
    width: 1px;
    background: rgba(255, 255, 255, 0.08);
  }
  .stat-num {
    font-family: var(--mono);
    font-size: 28px;
    font-weight: 700;
    color: var(--accent-light);
