---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { SITE } from '../../../data/site';

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Managed Security Services',
    description:
      'Continuous security monitoring, vulnerability management, and cybersecurity advisory for organisations in Rwanda and East Africa.',
    provider: {
      '@type': 'Organization',
      name: 'imizicyber',
      url: SITE.url,
      address: { '@type': 'PostalAddress', addressLocality: 'Kigali', addressCountry: 'RW' },
    },
    areaServed: ['RW', 'KE', 'UG', 'TZ'],
    url: `${SITE.url}/services/managed-security/`,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE.url}/` },
      { '@type': 'ListItem', position: 2, name: 'Services', item: `${SITE.url}/#services` },
      {
        '@type': 'ListItem',
        position: 3,
        name: 'Managed Security',
        item: `${SITE.url}/services/managed-security/`,
      },
    ],
  },
];
---

<BaseLayout
  title="Managed Security Services in Kigali, Rwanda | imizicyber"
  description="Continuous security monitoring, vulnerability management, and managed detection for banks and enterprises in Kigali and East Africa. Monthly retainer with SLAs."
  keywords="managed security services Kigali, managed security Rwanda, MSSP Rwanda, continuous security monitoring East Africa, managed detection response Rwanda, security operations East Africa"
  ogTitle="Managed Security Services in Kigali, Rwanda | imizicyber"
  ogDescription="Continuous monitoring, vulnerability management, and incident response for East African organisations. Monthly retainer, guaranteed SLAs."
  twitterTitle="Managed Security Services in Kigali, Rwanda"
  twitterDescription="Continuous monitoring and incident response for East African organisations. Monthly retainer, guaranteed SLAs."
  canonicalUrl={`${SITE.url}/services/managed-security/`}
  schemas={schemas}
  whatsappMessage="Hi imizicyber, I'd like to discuss managed security services"
  navVariant="inner"
  footerVariant="inner"
>
  <main id="main">
    <div class="hero">
      <div class="w">
        <div class="breadcrumb">
          <a href="/">Home</a><span class="sep">/</span><a href="/#services">Services</a><span
            class="sep">/</span
          ><span>Managed Security</span>
        </div>
        <span class="hero-badge">MANAGED SECURITY SERVICES</span>
        <h1>Security that never sleeps.<br />Your team in Kigali.</h1>
        <p>
          Continuous monitoring, vulnerability management, and cybersecurity advisory. Delivered as
          a monthly service, not a one-time project. Built for East African banks, fintechs, and
          enterprises.
        </p>
        <a href="/#contact" class="btn">Request a managed security quote</a>
        <a href="/tools/security-score/" class="btn btn-ghost">Assess your posture</a>
      </div>
    </div>

    <div class="section">
      <div class="w">
        <div class="services-grid">
          <div class="service-card">
            <div class="service-icon">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"
                ></polyline></svg
              >
            </div>
            <h3>External Perimeter Monitoring</h3>
            <p>
              Continuous monitoring of your external attack surface. Domain and subdomain discovery,
              exposed service detection, certificate tracking, and immediate alerting on new
              exposures.
            </p>
          </div>
          <div class="service-card">
            <div class="service-icon">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg
              >
            </div>
            <h3>Vulnerability Management</h3>
            <p>
              Monthly authenticated vulnerability scanning of all in-scope assets. Findings
              prioritised by exploitability and business impact. Patch tracking and remediation
              verification.
            </p>
          </div>
          <div class="service-card">
            <div class="service-icon">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path
                  d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg
              >
            </div>
            <h3>Cybersecurity Advisory</h3>
            <p>
              Board-level cybersecurity advisory. Risk posture briefings, strategic security
              roadmap, regulatory alignment, and practical guidance for leadership teams.
            </p>
          </div>
          <div class="service-card">
            <div class="service-icon">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path
                  d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg
              >
            </div>
            <h3>SAST / DAST Integration</h3>
            <p>
              Integrate static and dynamic application security testing into your development
              pipeline. Findings surfaced in your existing ticketing system. Weekly reports for
              development teams.
            </p>
          </div>
          <div class="service-card">
            <div class="service-icon">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"
                ></line><line x1="6" y1="20" x2="6" y2="14"></line></svg
              >
            </div>
            <h3>Security Reporting & Compliance</h3>
            <p>
              Monthly executive dashboard. BNR-aligned compliance reporting. Evidence packages for
              ISO 27001 and SWIFT CSP audits. Board-ready summaries each quarter.
            </p>
          </div>
          <div class="service-card">
            <div class="service-icon">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"
                ></line></svg
              >
            </div>
            <h3>Threat Intelligence</h3>
            <p>
              Contextualised threat intelligence relevant to East African financial institutions.
              Early warning on new vulnerabilities affecting your technology stack. Dark web
              monitoring for credential leaks and data breaches.
            </p>
          </div>
        </div>
      </div>
    </div>

    <div class="section">
      <div class="wn">
        <h2>Why managed security instead of ad-hoc testing?</h2>
        <p>
          A one-time annual penetration test is a snapshot. It tells you your security posture on a
          single day. But attackers operate continuously, probing your systems every day, looking
          for new vulnerabilities introduced by software updates, configuration changes, or new
          deployments.
        </p>

        <p>A managed security service provides continuous coverage:</p>
        <ul>
          <li>New vulnerabilities are detected within days, not 12 months</li>
          <li>
            Your board gets regular cybersecurity posture briefings without hiring a full-time CISO
          </li>
          <li>Your security posture is actively maintained, not reviewed once a year</li>
          <li>
            Compliance reporting is always ready, not assembled in a rush before an inspection
          </li>
          <li>
            You have on-demand security expertise without the recruitment cost of a full-time hire
          </li>
        </ul>

        <div class="callout">
          <strong>For BNR-regulated institutions:</strong> A managed security retainer satisfies BNR's
          requirements for continuous vulnerability management and security monitoring. We provide the
          compliance evidence your inspection team needs.
        </div>

        <h2>Service tiers</h2>
        <p>
          We offer three managed security tiers designed for different stages of security maturity
          and organisation size:
        </p>
      </div>
      <div class="w">
        <div class="tiers">
          <div class="tier">
            <div class="tier-name">ESSENTIALS</div>
            <h3>Monitor</h3>
            <div class="tier-price">For SMEs and early-stage fintechs</div>
            <ul>
              <li>Monthly vulnerability scanning</li>
              <li>External asset monitoring</li>
              <li>Monthly security report</li>
              <li>Email/WhatsApp alert channel</li>
              <li>Quarterly security posture review</li>
              <li>Annual pentest (included)</li>
            </ul>
          </div>
          <div class="tier featured">
            <div class="tier-name">PROFESSIONAL &nbsp;&#9733; MOST POPULAR</div>
            <h3>Protect</h3>
            <div class="tier-price">For banks, MFIs, and growing fintechs</div>
            <ul>
              <li>Everything in Essentials</li>
              <li>Continuous perimeter monitoring</li>
              <li>Quarterly penetration testing</li>
              <li>SAST/DAST pipeline integration</li>
              <li>Quarterly cybersecurity advisory session</li>
              <li>BNR compliance evidence package</li>
              <li>Monthly executive dashboard</li>
              <li>Dedicated analyst point of contact</li>
            </ul>
          </div>
          <div class="tier">
            <div class="tier-name">ENTERPRISE</div>
            <h3>Defend</h3>
            <div class="tier-price">For large banks and multi-country operations</div>
            <ul>
              <li>Everything in Professional</li>
              <li>Monthly board-level advisory</li>
              <li>Threat intelligence feed</li>
              <li>Dark web monitoring</li>
              <li>Custom dark web monitoring scope</li>
              <li>On-site quarterly reviews</li>
              <li>SWIFT CSP compliance support</li>
              <li>ISO 27001 audit support</li>
              <li>Custom SLA and scope</li>
            </ul>
          </div>
        </div>
      </div>
      <div class="wn">
        <p>
          All tiers include a kickoff assessment, asset discovery, and onboarding. Pricing is on
          request. We scope engagements to your specific environment and provide a fixed monthly
          quote with no surprises.
        </p>

        <h2>Who we work with</h2>
        <p>
          Our managed security clients include banks and MFIs supervised by <a
            href="https://www.bnr.rw/"
            target="_blank"
            rel="noopener noreferrer">BNR</a
          >, payment service providers, mobile money operators, insurance companies, and technology
          companies serving the financial sector across Rwanda and East Africa. Our team is based in
          Kigali and available for on-site work when required.
        </p>

        <p>
          Related services: <a href="/services/penetration-testing/">penetration testing</a> and <a
            href="/services/security-training/">security awareness training</a
          >. For the full picture of what we cover, see our guide to <a
            href="/blog/penetration-testing-rwanda/">penetration testing in Rwanda</a
          >.
        </p>
      </div>
    </div>

    <div class="wn">
      <div class="cta-section">
        <h2>Get a managed security quote</h2>
        <p>
          Tell us about your environment and we will scope a proposal within 48 hours. No
          obligation, no sales pressure.
        </p>
        <a href="/#contact" class="btn">Request a quote</a>
        <a href="/tools/security-score/" class="btn btn-ghost">Assess your posture first</a>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .w {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .wn {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .hero {
    padding: 120px 0 60px;
    text-align: center;
  }
  .hero-badge {
    display: inline-block;
    font-family: var(--mono);
    font-size: 0.64rem;
    color: var(--acc);
    letter-spacing: 0.1em;
    margin-bottom: 16px;
    background: rgba(52, 211, 153, 0.08);
    border: 1px solid rgba(52, 211, 153, 0.2);
    border-radius: 20px;
    padding: 5px 14px;
  }
  .hero h1 {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 800;
    letter-spacing: -1.5px;
    line-height: 1.1;
    color: var(--white);
    margin-bottom: 20px;
  }
  .breadcrumb {
    font-family: var(--mono);
    font-size: 0.64rem;
    color: var(--txt3);
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    flex-wrap: wrap;
  }
  .breadcrumb a {
    color: var(--txt3);
    text-decoration: none;
    transition: color 0.2s;
  }
  .breadcrumb a:hover {
    color: var(--acc);
  }
  .breadcrumb .sep {
    color: var(--dim);
  }
  .hero p {
    font-size: 1.08rem;
    color: var(--txt2);
    max-width: 540px;
    margin: 0 auto 32px;
    line-height: 1.75;
  }
  .btn {
    display: inline-block;
    padding: 13px 28px;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 700;
    text-decoration: none;
    background: var(--accdark);
    color: #fff;
    transition: all 0.2s;
  }
  .btn:hover {
    background: var(--acc2);
  }
  .btn-ghost {
    background: transparent;
    border: 1.5px solid var(--dim);
    color: var(--txt2);
    margin-left: 12px;
  }
  .btn-ghost:hover {
    border-color: var(--acc);
    color: var(--acc);
    background: transparent;
  }
  .section {
    padding: 60px 0;
  }
  h2 {
    font-size: 1.7rem;
    font-weight: 800;
    letter-spacing: -1px;
    color: var(--white);
    margin-bottom: 12px;
  }
  h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 8px;
  }
  p {
    margin-bottom: 14px;
    color: var(--txt);
    line-height: 1.8;
  }
  strong {
    color: var(--white);
  }
  a {
    color: var(--acc);
  }
  ul,
  ol {
    margin: 0 0 14px 20px;
  }
  li {
    margin-bottom: 6px;
    color: var(--txt);
    line-height: 1.7;
  }
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 20px;
    margin: 32px 0;
  }
  .service-card {
    background: var(--bg2);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 14px;
    padding: 28px;
  }
  .service-card:hover {
    border-color: rgba(52, 211, 153, 0.3);
    transform: translateY(-2px);
    transition: all 0.2s;
  }
  .service-icon {
    width: 44px;
    height: 44px;
    background: rgba(52, 211, 153, 0.1);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
  }
  .service-icon svg {
    width: 22px;
    height: 22px;
    stroke: var(--acc);
  }
  .service-card h3 {
    margin-bottom: 8px;
    font-size: 0.95rem;
  }
  .service-card p {
    font-size: 0.86rem;
    color: var(--txt2);
    margin: 0;
  }
  .tiers {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
    margin: 32px 0;
  }
  .tier {
    background: var(--bg2);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 14px;
    padding: 24px;
  }
  .tier.featured {
    border-color: var(--acc2);
    background: linear-gradient(135deg, rgba(52, 211, 153, 0.08), transparent);
  }
  .tier-name {
    font-family: var(--mono);
    font-size: 0.7rem;
    color: var(--acc);
    letter-spacing: 0.08em;
    margin-bottom: 8px;
  }
  .tier h3 {
    font-size: 1.2rem;
    color: var(--white);
    margin-bottom: 4px;
  }
  .tier-price {
    font-size: 0.84rem;
    color: var(--txt2);
    margin-bottom: 16px;
  }
  .tier ul {
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .tier ul li {
    font-size: 0.83rem;
    color: var(--txt2);
    padding: 5px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    display: flex;
    gap: 8px;
  }
  .tier ul li::before {
    content: '\2713';
    color: var(--acc);
    flex-shrink: 0;
    font-weight: 700;
  }
  .callout {
    background: var(--bg2);
    border-left: 3px solid var(--acc);
    padding: 16px 20px;
    margin: 20px 0;
    border-radius: 0 8px 8px 0;
    font-size: 0.88rem;
  }
  .cta-section {
    background: var(--bg2);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 16px;
    padding: 48px 40px;
    margin: 60px 0;
    text-align: center;
  }
  .cta-section h2 {
    margin-bottom: 12px;
  }
  .cta-section p {
    color: var(--txt2);
    max-width: 480px;
    margin: 0 auto 28px;
  }

  /* LIGHT THEME */
  [data-theme='light'] .service-card,
  [data-theme='light'] .tier,
  [data-theme='light'] .callout,
  [data-theme='light'] .cta-section {
    border-color: rgba(0, 0, 0, 0.1);
  }
  [data-theme='light'] .tier ul li {
    border-bottom-color: rgba(0, 0, 0, 0.06);
  }
  [data-theme='light'] .btn,
  [data-theme='light'] .btn:hover {
    color: #fff;
  }
  [data-theme='light'] .btn.btn-ghost {
    background: transparent;
    border-color: #4a5568;
    color: #2d3748;
  }
  [data-theme='light'] .btn.btn-ghost:hover {
    border-color: var(--acc);
    color: var(--acc);
  }

  /* RESPONSIVE - MOBILE */
  @media (max-width: 768px) {
    .hero {
      padding: 96px 0 48px;
    }
    .btn-ghost {
      margin-left: 0;
      margin-top: 8px;
    }
    .cta-section {
      padding: 36px 24px;
    }
  }

  /* RESPONSIVE - SMALL PHONE */
  @media (max-width: 480px) {
    .w,
    .wn {
      padding: 0 16px;
    }
    .hero {
      padding: 80px 0 36px;
    }
    .hero p {
      font-size: 0.94rem;
    }
    .section {
      padding: 40px 0;
    }
    .service-card {
      padding: 20px;
    }
  }
</style>
