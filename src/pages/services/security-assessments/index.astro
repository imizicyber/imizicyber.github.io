---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { SITE } from '../../../data/site';

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'Security Assessment Services',
    provider: {
      '@type': 'ProfessionalService',
      name: 'imizicyber',
      url: SITE.url,
      '@id': `${SITE.url}/#organization`,
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Norrsken House',
        addressLocality: 'Kigali',
        addressCountry: 'RW',
      },
    },
    serviceType: 'Security Assessments',
    description:
      'Comprehensive security assessments for financial institutions, telecoms, and government agencies across East Africa. Vulnerability assessments, configuration audits, cloud security reviews, compliance gap analysis, source code review, and architecture review.',
    areaServed: [
      { '@type': 'Country', name: 'Rwanda' },
      { '@type': 'Country', name: 'Kenya' },
      { '@type': 'Country', name: 'Uganda' },
      { '@type': 'Country', name: 'Tanzania' },
      { '@type': 'Place', name: 'East Africa' },
      { '@type': 'Country', name: 'South Africa' },
      { '@type': 'Place', name: 'Southern Africa' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'How long does a security assessment take?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Timelines vary by scope. A focused vulnerability assessment may take 3-5 business days, while a comprehensive assessment covering infrastructure, applications, and compliance gaps typically requires 2-4 weeks.',
        },
      },
      {
        '@type': 'Question',
        name: 'What certifications do your assessors hold?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Our lead consultant holds OSCP and OSCP+ and PNPT certifications, with hands-on security assessment experience at Tier-1 European and African banking institutions and a presentation at BlackHat Europe Arsenal.',
        },
      },
      {
        '@type': 'Question',
        name: 'What is the difference between a security assessment and a penetration test?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'A security assessment is broader in scope: it evaluates your security posture across configurations, policies, architecture, and code. A penetration test is a focused adversarial simulation that exploits specific vulnerabilities. We often recommend both as complementary engagements.',
        },
      },
      {
        '@type': 'Question',
        name: 'How much does a security assessment cost in Rwanda?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Every engagement is scoped individually based on the number of systems, assessment depth, and compliance requirements. Contact us with your requirements for a tailored quote within 48 hours.',
        },
      },
      {
        '@type': 'Question',
        name: 'What do we receive after the assessment?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'A comprehensive report with executive summary, detailed findings with evidence, risk ratings, compliance mapping, prioritised remediation guidance, a live debrief session, and ongoing support during remediation.',
        },
      },
      {
        '@type': 'Question',
        name: 'Do you assess cloud environments?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes. We assess AWS, Azure, and GCP environments including IAM configurations, network security, storage permissions, logging, and compliance with cloud security benchmarks such as CIS.',
        },
      },
      {
        '@type': 'Question',
        name: 'Can you help us prepare for a compliance audit?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Absolutely. Our compliance gap analysis identifies gaps against BNR, PCI DSS, ISO 27001, and Rwanda Data Protection Law requirements before your audit, giving you time to remediate and build evidence.',
        },
      },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE.url}/` },
      { '@type': 'ListItem', position: 2, name: 'Services', item: `${SITE.url}/#services` },
      {
        '@type': 'ListItem',
        position: 3,
        name: 'Security Assessments',
        item: `${SITE.url}/services/security-assessments/`,
      },
    ],
  },
];
---

<BaseLayout
  title="Security Assessments Rwanda & East Africa | imizicyber"
  description="Comprehensive security assessments for banks, telecoms, and government agencies in Kigali and East Africa. Vulnerability assessments, configuration audits, cloud security reviews, and compliance gap analysis."
  keywords="security assessment Rwanda, vulnerability assessment Kigali, security audit East Africa, VAPT Rwanda, configuration audit Rwanda, cloud security assessment Kigali, compliance gap analysis Rwanda, source code review East Africa, architecture review Rwanda, BNR compliance assessment, PCI DSS gap analysis, ISO 27001 security assessment, security posture review Rwanda"
  ogTitle="Security Assessment Services in Kigali, Rwanda | imizicyber"
  ogDescription="Comprehensive security assessments for banks, telecoms, and government agencies in Kigali and East Africa. Vulnerability assessments, configuration audits, and compliance gap analysis."
  twitterTitle="Security Assessments in Rwanda | imizicyber"
  twitterDescription="Comprehensive security assessments for regulated organisations in Kigali and East Africa."
  canonicalUrl={`${SITE.url}/services/security-assessments/`}
  schemas={schemas}
  whatsappMessage="Hi imizicyber, I'd like to discuss security assessments"
  navVariant="inner"
  footerVariant="inner"
>
  <main id="main">
    <div class="w">
      <div class="article-header">
        <div class="breadcrumb">
          <a href="/">Home</a><span class="sep">/</span><a href="/#services">Services</a><span
            class="sep">/</span
          ><span>Security Assessments</span>
        </div>
        <div class="article-meta">
          <span class="label">SERVICE</span>
          <span class="sep">&middot;</span>
          <span class="detail">KIGALI, RWANDA</span>
        </div>
        <h1>Security assessments for banks and regulated organisations in Rwanda</h1>
        <p class="article-intro">
          Comprehensive security assessments for financial institutions, telecoms, and government
          agencies across East Africa. We evaluate your security posture across infrastructure,
          applications, configurations, and compliance. Manual-first, not scanner-repackaged.
        </p>
        <div class="cred-bar">
          <span>Certifications:</span>
          <strong>OSCP / OSCP+</strong>
          <strong>PNPT</strong>
          <span class="cred-sep">|</span>
          <strong>BlackHat Europe Arsenal presenter</strong>
          <span class="cred-sep">|</span>
          <span>Assessment experience at Tier-1 European &amp; African banks</span>
        </div>
      </div>
    </div>

    <!-- ASSESSMENT TYPE CARDS -->
    <div class="cards-section">
      <div class="cards-grid">
        <div class="card">
          <div class="card-icon">
            <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"
              ><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg
            >
          </div>
          <div class="card-num">01</div>
          <h3>Vulnerability assessment</h3>
          <p>
            Systematic identification of security weaknesses across your infrastructure and
            applications. Manual validation eliminates false positives and prioritises real risk.
          </p>
        </div>
        <div class="card">
          <div class="card-icon">
            <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"
              ><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"
              ></polyline></svg
            >
          </div>
          <div class="card-num">02</div>
          <h3>Configuration audit</h3>
          <p>
            Review of server, network, database, and application configurations against security
            benchmarks. Misconfigurations are the most common attack vector.
          </p>
        </div>
        <div class="card">
          <div class="card-icon">
            <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"
              ><path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"></path></svg
            >
          </div>
          <div class="card-num">03</div>
          <h3>Cloud security assessment</h3>
          <p>
            AWS, Azure, and GCP environment reviews covering IAM, network security, storage
            permissions, logging, and compliance with CIS benchmarks.
          </p>
        </div>
        <div class="card">
          <div class="card-icon">
            <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"
              ><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline
                points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line
                x1="16"
                y1="17"
                x2="8"
                y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg
            >
          </div>
          <div class="card-num">04</div>
          <h3>Compliance gap analysis</h3>
          <p>
            Map your current security controls against BNR, PCI DSS, ISO 27001, and Rwanda Data
            Protection Law requirements. Identify gaps before your auditor does.
          </p>
        </div>
        <div class="card">
          <div class="card-icon">
            <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"
              ><polyline points="16 18 22 12 16 6"></polyline><polyline points="8 6 2 12 8 18"
              ></polyline><line x1="14" y1="4" x2="10" y2="20"></line></svg
            >
          </div>
          <div class="card-num">05</div>
          <h3>Source code review</h3>
          <p>
            Manual code analysis for security vulnerabilities including injection flaws, insecure
            authentication, hardcoded credentials, and business logic errors.
          </p>
        </div>
        <div class="card">
          <div class="card-icon">
            <svg viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round"
              ><rect x="2" y="2" width="20" height="8" rx="2" ry="2"></rect><rect
                x="2"
                y="14"
                width="20"
                height="8"
                rx="2"
                ry="2"></rect><line x1="6" y1="6" x2="6.01" y2="6"></line><line
                x1="6"
                y1="18"
                x2="6.01"
                y2="18"></line></svg
            >
          </div>
          <div class="card-num">06</div>
          <h3>Architecture review</h3>
          <p>
            Evaluate your system architecture for security weaknesses: network segmentation, data
            flows, trust boundaries, and defence-in-depth design.
          </p>
        </div>
      </div>
    </div>

    <!-- BODY -->
    <div class="w article-body">
      <h2>Why imizicyber</h2>
      <p>
        Most assessment firms run automated scanners, repackage the output into a PDF, and present
        it as a security assessment. That approach floods you with false positives and misses the
        vulnerabilities that actually matter: the misconfigurations specific to your environment,
        the business logic gaps that scanners cannot detect, and the compliance shortfalls that will
        surface during your next audit.
      </p>
      <p>
        imizicyber takes a manual-first approach. Our assessments are led by consultants with
        hands-on experience at Tier-1 banking institutions across Europe and Africa. We have
        identified critical misconfigurations in banking infrastructure, uncovered insecure data
        flows in financial applications, and mapped compliance gaps that automated tools completely
        missed.
      </p>
      <p>
        When you engage us for a security assessment, you get expert analysis tailored to your
        specific environment, not a generic scanner report with your logo on it. For organisations
        that also need adversarial testing, we recommend combining assessments with our
        <a href="/services/penetration-testing/">penetration testing</a> service.
      </p>

      <h2>How a security assessment works</h2>
      <p>
        Every engagement follows a structured methodology. Clear scope, transparent process, and
        actionable outcomes.
      </p>

      <div class="process-timeline">
        <div class="p-step">
          <h3>Scoping</h3>
          <p>
            We define the assessment scope, objectives, and success criteria together. You know
            exactly what will be assessed, which frameworks apply, and what deliverables to expect.
          </p>
        </div>
        <div class="p-step">
          <h3>Asset discovery</h3>
          <p>
            Comprehensive mapping of your systems, applications, network segments, and data flows.
            We identify assets you may not know are exposed.
          </p>
        </div>
        <div class="p-step">
          <h3>Assessment</h3>
          <p>
            Manual and tool-assisted evaluation of each asset against security benchmarks and
            compliance requirements. We validate every finding by hand.
          </p>
        </div>
        <div class="p-step">
          <h3>Analysis</h3>
          <p>
            Correlation of findings across systems to identify systemic issues, attack paths, and
            risk patterns. Individual weaknesses are mapped to real business impact.
          </p>
        </div>
        <div class="p-step">
          <h3>Reporting</h3>
          <p>
            Detailed report with executive summary, technical findings with evidence, risk ratings,
            compliance mapping, and prioritised remediation guidance.
          </p>
        </div>
        <div class="p-step">
          <h3>Remediation support</h3>
          <p>
            Debrief session with your team. We walk through every finding and provide ongoing
            support as you implement fixes. Free verification of remediated issues.
          </p>
        </div>
      </div>

      <h2>Who this is for</h2>
      <p>
        Our security assessments are designed for organisations where a breach means regulatory
        consequences, financial loss, and eroded public trust.
      </p>
      <ul>
        <li>
          <strong>Banks and financial institutions</strong>: BNR-regulated commercial banks,
          microfinance institutions, and payment service providers across Rwanda and East Africa
        </li>
        <li>
          <strong>Telecoms and mobile money operators</strong>: organisations handling millions of
          financial transactions daily
        </li>
        <li>
          <strong>Government agencies</strong>: ministries and public institutions managing citizen
          data and critical national infrastructure
        </li>
        <li>
          <strong>Insurance companies</strong>: firms managing sensitive policyholder data under
          evolving regulatory requirements
        </li>
        <li>
          <strong>Fintechs and startups</strong>: fast-moving companies that need security
          validation before launch or fundraising
        </li>
      </ul>

      <!-- BNR directive numbers sourced from public regulatory gazette; verify at bnr.rw before publishing -->
      <h2>Compliance alignment</h2>
      <p>
        Security assessments are a requirement under multiple frameworks that apply to financial
        institutions in Rwanda and East Africa. Our methodology and reporting satisfy:
      </p>
      <ul>
        <li>
          <strong>BNR Regulation No 16/2023 on Cybersecurity</strong>: Article 13 requires
          supervised institutions to conduct regular vulnerability assessments as part of their
          cybersecurity programme. Article 9 mandates an annual review of the institution's
          cybersecurity programme, which must include independent security assessment
        </li>
        <li>
          <strong>PCI DSS v4.0</strong>: Requirement 6.2 requires secure development practices and
          software security testing. Requirement 11.3 mandates quarterly vulnerability scanning and
          risk-based assessment of security controls across the cardholder data environment
        </li>
        <li>
          <strong>ISO 27001:2022</strong>: Annex A Control 8.8 (Management of technical
          vulnerabilities) requires timely identification and remediation of vulnerabilities.
          Control 5.36 (Compliance with policies, rules and standards) mandates independent security
          reviews of information security implementation
        </li>
        <li>
          <strong>Rwanda Data Protection Law No 058/2021</strong>: Article 30 requires data
          controllers to implement appropriate technical and organisational measures to protect
          personal data. Security assessments demonstrate compliance with this obligation
        </li>
      </ul>
      <p>
        Our reports include the executive summary, technical detail, and remediation evidence that
        auditors and regulators expect. For more on BNR requirements, see our guide on <a
          href="/blog/bnr-cybersecurity-requirements/"
          >BNR cybersecurity requirements for banks in Rwanda</a
        >.
      </p>

      <h2>Frequently asked questions</h2>

      <details class="faq">
        <summary>How long does a security assessment take?</summary>
        <div class="faq-body">
          Timelines vary by scope. A focused vulnerability assessment may take 3-5 business days,
          while a comprehensive assessment covering infrastructure, applications, and compliance
          gaps typically requires 2-4 weeks. We provide a detailed timeline during scoping.
        </div>
      </details>
      <details class="faq">
        <summary>What certifications do your assessors hold?</summary>
        <div class="faq-body">
          Our lead consultant holds OSCP and OSCP+ (Offensive Security Certified Professional) and
          PNPT (Practical Network Penetration Tester) certifications, with hands-on security
          assessment experience at Tier-1 European and African banking institutions and a
          presentation at BlackHat Europe Arsenal.
        </div>
      </details>
      <details class="faq">
        <summary
          >What is the difference between a security assessment and a penetration test?</summary
        >
        <div class="faq-body">
          A security assessment is broader in scope: it evaluates your overall security posture
          across configurations, policies, architecture, and code. A penetration test is a focused
          adversarial simulation that exploits specific vulnerabilities to demonstrate impact. We
          often recommend both as complementary engagements. Learn more in our article on
          <a href="/blog/penetration-testing-vs-vulnerability-assessment-banks/"
            >penetration testing vs vulnerability assessment for banks</a
          >.
        </div>
      </details>
      <details class="faq">
        <summary>How much does a security assessment cost in Rwanda?</summary>
        <div class="faq-body">
          Every engagement is scoped individually based on the number of systems, assessment depth,
          and compliance requirements. Contact us with your requirements for a tailored quote within
          48 hours.
        </div>
      </details>
      <details class="faq">
        <summary>What do we receive after the assessment?</summary>
        <div class="faq-body">
          A comprehensive report including an executive summary for management, detailed technical
          findings with evidence, risk ratings, compliance mapping against relevant frameworks,
          prioritised remediation guidance, a live debrief session, and ongoing support during
          remediation.
        </div>
      </details>
      <details class="faq">
        <summary>Do you assess cloud environments?</summary>
        <div class="faq-body">
          Yes. We assess AWS, Azure, and GCP environments including IAM configurations, network
          security, storage permissions, logging, and compliance with cloud security benchmarks such
          as CIS. Cloud assessments can be conducted independently or as part of a broader security
          review.
        </div>
      </details>
      <details class="faq">
        <summary>Can you help us prepare for a compliance audit?</summary>
        <div class="faq-body">
          Absolutely. Our compliance gap analysis identifies gaps against BNR, PCI DSS, ISO 27001,
          and Rwanda Data Protection Law requirements before your audit, giving you time to
          remediate and build evidence. We provide a prioritised roadmap so you address the most
          critical gaps first.
        </div>
      </details>

      <!-- CTA -->
      <div class="cta-box">
        <h2>Request a security assessment</h2>
        <p>
          Tell us what you need assessed. We respond within 24 hours with a scoping call and
          detailed proposal.
        </p>
        <div class="cta-btns">
          <a href="/#contact" class="btn btn-fill">Request a security assessment</a>
          <a
            href={`https://wa.me/250793146617?text=${encodeURIComponent("Hi imizicyber, I'd like to discuss security assessments")}`}
            class="btn btn-wa"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg viewBox="0 0 24 24"
              ><path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"
              ></path><path
                d="M12 0C5.373 0 0 5.373 0 12c0 2.625.846 5.059 2.284 7.034L.789 23.492a.5.5 0 00.611.611l4.458-1.495A11.952 11.952 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.75c-2.16 0-4.16-.696-5.788-1.876l-.404-.3-2.645.886.886-2.645-.3-.404A9.724 9.724 0 012.25 12C2.25 6.615 6.615 2.25 12 2.25S21.75 6.615 21.75 12 17.385 21.75 12 21.75z"
              ></path></svg
            >
            WhatsApp us
          </a>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<script>
  import { trackEvent } from '@/scripts/analytics';
  document.querySelectorAll('a[href*="wa.me"]').forEach((link) => {
    if (!link.closest('.wa-float')) {
      link.addEventListener('click', () => {
        trackEvent('whatsapp_click', {
          page: window.location.pathname,
          location: 'cta_section',
        });
      });
    }
  });
</script>

<style>
  /* Blog-style narrow container */
  .w {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* HEADER */
  .breadcrumb {
    font-family: var(--mono);
    font-size: 0.64rem;
    color: var(--txt3);
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }
  .breadcrumb a {
    color: var(--txt3);
    text-decoration: none;
    transition: color 0.2s;
  }
  .breadcrumb a:hover {
    color: var(--acc);
  }
  .breadcrumb .sep {
    color: var(--dim);
  }
  .article-header {
    padding: 100px 0 36px;
  }
  .article-meta {
    font-family: var(--mono);
    font-size: 0.64rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    margin-bottom: 18px;
  }
  .article-meta .label {
    color: var(--acc);
  }
  .article-meta .sep {
    color: var(--txt3);
    margin: 0 6px;
  }
  .article-meta .detail {
    color: #f59e0b;
  }

  h1 {
    font-size: clamp(1.7rem, 4vw, 2.3rem);
    font-weight: 800;
    letter-spacing: -1px;
    line-height: 1.12;
    color: var(--white);
    margin-bottom: 14px;
  }
  .article-intro {
    font-size: 0.92rem;
    color: var(--txt2);
    line-height: 1.7;
    max-width: 560px;
  }

  /* CRED BAR */
  .cred-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    align-items: center;
    padding: 16px 0;
    margin-top: 18px;
    border-top: 1px solid rgba(255, 255, 255, 0.04);
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    font-size: 0.7rem;
    color: var(--txt3);
  }
  .cred-bar strong {
    color: var(--txt2);
    font-weight: 700;
  }
  .cred-sep {
    color: var(--dim);
  }

  /* BODY CONTENT */
  .article-body h2 {
    font-size: clamp(1.15rem, 2vw, 1.4rem);
    font-weight: 800;
    letter-spacing: -0.5px;
    color: var(--white);
    margin-top: 40px;
    margin-bottom: 10px;
    line-height: 1.2;
  }
  .article-body p {
    margin-bottom: 14px;
    font-size: 0.88rem;
    color: var(--txt);
    line-height: 1.75;
  }
  .article-body a {
    color: var(--acc);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .article-body a:hover {
    text-decoration: none;
  }
  .article-body a.btn {
    text-decoration: none;
  }
  .article-body ul {
    list-style: none;
    margin-bottom: 18px;
    padding: 0;
  }
  .article-body li {
    padding: 4px 0 4px 18px;
    position: relative;
    font-size: 0.84rem;
    line-height: 1.7;
    color: var(--txt);
  }
  .article-body li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 11px;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--acc);
  }
  .article-body strong {
    color: var(--white);
    font-weight: 700;
  }

  /* CARDS */
  .cards-section {
    max-width: 920px;
    margin: 28px auto 20px;
    padding: 0 24px;
  }
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }
  .card {
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 12px;
    padding: 24px 20px;
    background: var(--bg2);
    transition: all 0.25s;
    position: relative;
