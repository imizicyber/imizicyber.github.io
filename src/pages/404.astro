---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../data/site';
---

<BaseLayout
  title="Page Not Found | imizicyber"
  description="The page you are looking for does not exist."
  canonicalUrl={`${SITE.url}/404/`}
  robots="noindex, nofollow"
  showWhatsApp={false}
>
  <main id="main">
    <section class="hero-404">
      <div class="w">
        <div class="code">404</div>
        <h1>Page not found</h1>
        <p>The page you are looking for does not exist, has been moved, or is temporarily unavailable.</p>
        <div class="btns">
          <a href="/" class="btn btn-fill">Back to homepage</a>
          <a href="/#services" class="btn btn-ghost">Our services</a>
          <a href="/#contact" class="btn btn-ghost">Contact us</a>
        </div>
        <div class="terminal">
          <div class="terminal-bar">
            <span class="terminal-dot"></span>
            <span class="terminal-dot"></span>
            <span class="terminal-dot"></span>
          </div>
          <div class="terminal-body">
            <div><span class="prompt">$ </span>curl -I https://imizicyber.com/this-page</div>
            <div><span class="result">HTTP/2 404</span></div>
            <div><span class="result">x-served-by: imizicyber</span></div>
            <div style="margin-top:8px"><span class="prompt">$ </span>echo "Try /services/ or /blog/ instead"</div>
            <div><span class="result">Try /services/ or /blog/ instead</span></div>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .hero-404{padding:140px 0 80px;text-align:center}
  .code{font-family:var(--mono);font-size:clamp(4rem,10vw,7rem);font-weight:800;color:var(--acc);letter-spacing:-4px;margin-bottom:16px;opacity:.85}
  h1{font-size:clamp(1.4rem,3vw,1.8rem);font-weight:800;color:var(--white);letter-spacing:-.5px;margin-bottom:12px}
  p{color:var(--txt2);margin-bottom:28px;font-size:.95rem}
  .terminal{max-width:460px;margin:40px auto 0;background:var(--bg2);border:1px solid rgba(255,255,255,.06);border-radius:10px;overflow:hidden;text-align:left}
  .terminal-bar{display:flex;align-items:center;gap:6px;padding:10px 14px;background:rgba(0,0,0,.2);border-bottom:1px solid rgba(255,255,255,.04)}
  .terminal-dot{width:10px;height:10px;border-radius:50%;background:rgba(255,255,255,.12)}
  .terminal-body{padding:14px 16px;font-family:var(--mono);font-size:.75rem;line-height:1.8;color:var(--txt2)}
  .prompt{color:var(--acc)}
  .result{color:var(--txt3)}
</style>
