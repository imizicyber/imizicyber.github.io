    color: var(--white);
    margin-bottom: 14px;
  }
  .page-header p {
    color: var(--txt2);
    font-size: 1rem;
    max-width: 520px;
    margin: 0 auto;
  }
  .resources-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 24px;
    margin-bottom: 60px;
  }
  .resource-card {
    background: var(--bg2);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 16px;
    overflow: hidden;
    transition: border-color 0.2s;
  }
  .resource-card:hover {
    border-color: rgba(52, 211, 153, 0.3);
  }
  .res-header {
    padding: 24px 24px 0;
