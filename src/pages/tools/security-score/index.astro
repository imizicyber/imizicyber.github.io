---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { SITE } from '../../../data/site';

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'Free Security Score Assessment',
    description: 'Answer 10 questions and get an instant security score with a free PDF report.',
    url: `${SITE.url}/tools/security-score/`,
    publisher: {
      '@type': 'Organization',
      name: SITE.name,
      url: SITE.url,
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE.url}/` },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'Security Score',
        item: `${SITE.url}/tools/security-score/`,
      },
    ],
  },
];
---

<BaseLayout
  title="Free Security Score Assessment | imizicyber"
  description="Answer 10 questions and get an instant security score for your organisation. Free PDF report with prioritised recommendations. No registration required."
  keywords="security score assessment, cybersecurity assessment Rwanda, free security audit East Africa, security maturity assessment, cybersecurity quiz Rwanda, offensive security East Africa"
  ogTitle="Free Security Score Assessment | imizicyber"
  ogDescription="10 questions. Instant score. Free PDF report with prioritised security recommendations."
  canonicalUrl={`${SITE.url}/tools/security-score/`}
  twitterTitle="Free Security Score Assessment | imizicyber"
  twitterDescription="10 questions. Instant score. Free PDF report with prioritised security recommendations."
  schemas={schemas}
>
  <main id="main">
    <div class="w">
      <div class="page-header">
        <div class="page-badge">FREE SECURITY ASSESSMENT</div>
        <h1>What is your organisation's security score?</h1>
        <p>
          10 questions. 3 minutes. Instant score with a free PDF report containing prioritised
          recommendations.
        </p>
      </div>

      <div class="progress-bar">
        <div class="progress-fill" id="progress" style="width:0%"></div>
      </div>

      <form id="quiz-form">
        <div class="quiz-card" id="q1">
          <div class="q-num">QUESTION 1 OF 10</div>
          <div class="q-text">How often does your organisation conduct penetration testing?</div>
          <div class="options">
            <label class="option"
              ><input type="radio" name="q1" value="0" /> Never or don't know</label
            >
            <label class="option"
              ><input type="radio" name="q1" value="1" /> Only when required by a regulator</label
            >
            <label class="option"><input type="radio" name="q1" value="2" /> Annually</label>
            <label class="option"
              ><input type="radio" name="q1" value="3" /> Quarterly or more frequently</label
            >
          </div>
        </div>

        <div class="quiz-card" id="q2">
          <div class="q-num">QUESTION 2 OF 10</div>
          <div class="q-text">Do you have a tested incident response plan?</div>
          <div class="options">
            <label class="option"><input type="radio" name="q2" value="0" /> No plan exists</label>
            <label class="option"
              ><input type="radio" name="q2" value="1" /> Informal understanding but nothing documented</label
            >
            <label class="option"
              ><input type="radio" name="q2" value="2" /> Documented plan, but never tested</label
            >
            <label class="option"
              ><input type="radio" name="q2" value="3" /> Documented and tested with regular drills</label
            >
          </div>
        </div>

        <div class="quiz-card" id="q3">
          <div class="q-num">QUESTION 3 OF 10</div>
          <div class="q-text">
            What level of security awareness training does your organisation provide?
          </div>
          <div class="options">
            <label class="option"><input type="radio" name="q3" value="0" /> None</label>
            <label class="option"
              ><input type="radio" name="q3" value="1" /> Ad hoc or informal conversations</label
            >
            <label class="option"
              ><input type="radio" name="q3" value="2" /> Annual training sessions</label
            >
            <label class="option"
              ><input type="radio" name="q3" value="3" /> Regular training including phishing simulations</label
            >
          </div>
        </div>

        <div class="quiz-card" id="q4">
          <div class="q-num">QUESTION 4 OF 10</div>
          <div class="q-text">How is access management and MFA handled in your organisation?</div>
          <div class="options">
            <label class="option"
              ><input type="radio" name="q4" value="0" /> Shared passwords, no individual accounts</label
            >
            <label class="option"
              ><input type="radio" name="q4" value="1" /> Individual accounts but no MFA</label
            >
            <label class="option"
              ><input type="radio" name="q4" value="2" /> MFA on some systems (email, banking)</label
            >
            <label class="option"
              ><input type="radio" name="q4" value="3" /> MFA enforced across all critical systems</label
            >
          </div>
        </div>

        <div class="quiz-card" id="q5">
          <div class="q-num">QUESTION 5 OF 10</div>
          <div class="q-text">How do you manage third-party and vendor security risk?</div>
          <div class="options">
            <label class="option"><input type="radio" name="q5" value="0" /> We don't</label>
            <label class="option"
              ><input type="radio" name="q5" value="1" /> Informal conversations during procurement</label
            >
            <label class="option"
              ><input type="radio" name="q5" value="2" /> We review vendor security documentation</label
            >
            <label class="option"
              ><input type="radio" name="q5" value="3" /> Formal vendor risk assessments with ongoing
              monitoring</label
            >
          </div>
        </div>

        <div class="quiz-card" id="q6">
          <div class="q-num">QUESTION 6 OF 10</div>
          <div class="q-text">
            How is customer and sensitive data encrypted in your organisation?
          </div>
          <div class="options">
            <label class="option"><input type="radio" name="q6" value="0" /> Not encrypted</label>
            <label class="option"
              ><input type="radio" name="q6" value="1" /> Encrypted in transit only (HTTPS)</label
            >
            <label class="option"
              ><input type="radio" name="q6" value="2" /> Encrypted in transit and at rest</label
            >
            <label class="option"
              ><input type="radio" name="q6" value="3" /> Encryption + data classification + access controls</label
            >
          </div>
        </div>

        <div class="quiz-card" id="q7">
          <div class="q-num">QUESTION 7 OF 10</div>
          <div class="q-text">How is vulnerability management and patching handled?</div>
          <div class="options">
            <label class="option"
              ><input type="radio" name="q7" value="0" /> Not managed or unknown patch status</label
            >
            <label class="option"
              ><input type="radio" name="q7" value="1" /> Reactive: we patch when something breaks</label
            >
            <label class="option"
              ><input type="radio" name="q7" value="2" /> Regular scanning with scheduled patching cycles</label
            >
            <label class="option"
              ><input type="radio" name="q7" value="3" /> Continuous vulnerability management with defined
              patch SLAs</label
            >
          </div>
        </div>

        <div class="quiz-card" id="q8">
          <div class="q-num">QUESTION 8 OF 10</div>
          <div class="q-text">What web application and API security controls do you have?</div>
          <div class="options">
            <label class="option"><input type="radio" name="q8" value="0" /> None</label>
            <label class="option"
              ><input type="radio" name="q8" value="1" /> Basic firewall only</label
            >
            <label class="option"
              ><input type="radio" name="q8" value="2" /> Web Application Firewall (WAF)</label
            >
            <label class="option"
              ><input type="radio" name="q8" value="3" /> WAF + regular application penetration testing</label
            >
          </div>
        </div>

        <div class="quiz-card" id="q9">
          <div class="q-num">QUESTION 9 OF 10</div>
          <div class="q-text">Who is responsible for cybersecurity in your organisation?</div>
          <div class="options">
            <label class="option"
              ><input type="radio" name="q9" value="0" /> Nobody specifically</label
            >
            <label class="option"
              ><input type="radio" name="q9" value="1" /> The IT manager as an additional responsibility</label
            >
            <label class="option"
              ><input type="radio" name="q9" value="2" /> A dedicated security staff member or team</label
            >
            <label class="option"
              ><input type="radio" name="q9" value="3" /> CISO or equivalent with board-level reporting</label
            >
          </div>
        </div>

        <div class="quiz-card" id="q10">
          <div class="q-num">QUESTION 10 OF 10</div>
          <div class="q-text">
            What is your compliance status with relevant frameworks (BNR, PCI DSS, ISO 27001)?
          </div>
          <div class="options">
            <label class="option"
              ><input type="radio" name="q10" value="0" /> Unaware of requirements that apply to us</label
            >
            <label class="option"
              ><input type="radio" name="q10" value="1" /> Aware of requirements but not yet actioned</label
            >
            <label class="option"
              ><input type="radio" name="q10" value="2" /> Partially compliant: some controls in place</label
            >
            <label class="option"
              ><input type="radio" name="q10" value="3" /> Fully compliant and certified or attested</label
            >
          </div>
        </div>

        <button type="button" class="btn-calc" id="calc-btn" disabled
          >Calculate my security score &rarr;</button
        >
      </form>

      <div id="result-section">
        <div class="score-circle-wrap" id="score-display">
          <div class="score-circle" id="score-circle">
            <span class="score-num" id="score-num">0</span>
            <span class="score-max">/ 30</span>
          </div>
          <div class="band-label" id="band-label"></div>
          <div class="band-desc" id="band-desc"></div>
        </div>

        <div class="prelim-bullets" id="prelim-bullets">
          <h2>Key observations from your answers:</h2>
          <div id="bullets-content"></div>
        </div>

        <div class="gate-card">
          <h2>Download your full security report</h2>
          <p>
            Enter your details below to download a personalised PDF report with a detailed breakdown
            by category and prioritised recommendations.
          </p>
          <div id="gate-msg-success" class="msg-success">
            Your PDF is downloading now. Check your downloads folder.
          </div>
          <form id="gate-form">
            <input
              type="text"
              name="_gotcha"
              style="display:none"
              tabindex="-1"
              autocomplete="off"
              aria-hidden="true"
            />
            <div class="form-group">
              <label for="g-name">Name</label>
              <input type="text" id="g-name" name="name" placeholder="Your name" required />
            </div>
            <div class="form-group">
              <label for="g-email">Work email</label>
              <input
                type="email"
                id="g-email"
                name="email"
                placeholder="you@yourcompany.com"
                required
              />
            </div>
            <div class="form-group">
              <label for="g-org">Organisation</label>
              <input
                type="text"
                id="g-org"
                name="organisation"
                placeholder="Bank / fintech / company name"
                required
              />
            </div>
            <input type="hidden" name="tool" value="security-score" />
            <input type="hidden" name="score" id="h-score" value="" />
            <input type="hidden" name="band" id="h-band" value="" />
            <input type="hidden" name="answers" id="h-answers" value="" />
            <button type="submit" class="btn-submit" id="gate-submit-btn"
              >Download my report (PDF) &darr;</button
            >
            <div class="form-note">
              We never share your email. You may receive a follow-up from our team; unsubscribe
              anytime.
            </div>
          </form>
        </div>

        <div id="full-report">
          <div class="report-section">
            <h3>Detailed score breakdown</h3>
            <div id="breakdown-content"></div>
          </div>
          <div class="report-section">
            <h3>Prioritised recommendations</h3>
            <div id="recos-content"></div>
          </div>
          <div class="cta-report">
            <h3>Ready to close these gaps?</h3>
            <p>
              Our OSCP-certified team can help you address every finding in this report. Based in
              Kigali, available across East Africa and South Africa.
            </p>
            <a href="/#contact" class="btn-cta">Book a consultation</a>
            <p style="margin-top:14px;font-size:.82rem;color:var(--txt2)">
              Learn more: <a href="/blog/penetration-testing-rwanda/"
                >Penetration testing in Rwanda</a
              > &middot; <a href="/blog/bnr-cybersecurity-requirements/">BNR compliance guide</a> &middot;
              <a href="/resources/">Free resources</a>
            </p>
          </div>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .w {
    max-width: 640px;
    margin: 0 auto;
    padding: 0 20px;
  }
  main {
    padding: 88px 0 60px;
  }
  .page-header {
    text-align: center;
    padding: 32px 0 40px;
  }
  .page-badge {
    display: inline-block;
    font-family: var(--mono);
    font-size: 0.62rem;
    color: var(--acc);
    letter-spacing: 0.1em;
    margin-bottom: 14px;
    background: rgba(52, 211, 153, 0.08);
    border: 1px solid rgba(52, 211, 153, 0.2);
    border-radius: 20px;
    padding: 4px 12px;
  }
  .page-header h1 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 800;
    letter-spacing: -1px;
    line-height: 1.15;
    color: var(--white);
    margin-bottom: 12px;
  }
  .page-header p {
    color: var(--txt2);
    font-size: 1rem;
    max-width: 480px;
    margin: 0 auto;
  }
  .quiz-card {
    background: var(--bg2);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 16px;
    padding: 32px;
    margin-bottom: 20px;
    display: none;
  }
  .quiz-card.active {
    display: block;
    animation: slideDown 0.3s ease;
  }
  .q-back {
    display: inline-block;
    font-size: 0.78rem;
    color: var(--txt3);
    cursor: pointer;
    margin-bottom: 12px;
    background: none;
    border: none;
    font-family: var(--sans);
    padding: 0;
  }
  .q-back:hover {
    color: var(--acc);
  }
  .q-num {
    font-family: var(--mono);
    font-size: 0.62rem;
    color: var(--acc);
    letter-spacing: 0.08em;
    margin-bottom: 8px;
  }
  .q-text {
    font-size: 1rem;
    font-weight: 700;
    color: var(--white);
    margin-bottom: 18px;
    line-height: 1.5;
  }
  .options {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .option {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 11px 16px;
    background: var(--bg3);
    border: 1.5px solid rgba(255, 255, 255, 0.06);
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s;
    font-size: 0.88rem;
    color: var(--txt);
  }
  .option:hover {
    border-color: rgba(52, 211, 153, 0.4);
    background: rgba(52, 211, 153, 0.06);
  }
  .option input[type='radio'] {
    width: 16px;
    height: 16px;
    accent-color: var(--acc);
    flex-shrink: 0;
  }
  .option.selected {
    border-color: var(--acc2);
    background: rgba(52, 211, 153, 0.1);
    color: var(--white);
  }
  .progress-bar {
    height: 4px;
    background: var(--bg3);
    border-radius: 2px;
    margin: 0 0 32px;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--acc2), var(--acc));
    border-radius: 2px;
    transition: width 0.4s ease;
  }
  .btn-calc {
    display: block;
    width: 100%;
    padding: 14px;
    border: none;
    border-radius: 10px;
    background: var(--accdark);
    color: #fff;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    font-family: var(--sans);
    transition: all 0.2s;
    margin-top: 12px;
  }
  .btn-calc:hover {
    background: var(--acc2);
  }
  .btn-calc:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  #result-section {
    display: none;
  }
  #result-section.visible {
    display: block;
  }
  .score-circle-wrap {
    text-align: center;
    padding: 40px 0 32px;
  }
  .score-circle {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    margin: 0 auto 16px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    border: 5px solid;
  }
  .score-num {
    font-size: 2.8rem;
    font-weight: 800;
    line-height: 1;
  }
  .score-max {
    font-size: 0.8rem;
    font-weight: 400;
    opacity: 0.7;
    margin-top: 2px;
  }
  .band-label {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--white);
    margin-bottom: 6px;
  }
  .band-desc {
    font-size: 0.86rem;
    color: var(--txt2);
  }
  .band-critical .score-circle {
    border-color: #ef4444;
    background: rgba(239, 68, 68, 0.1);
  }
  .band-critical .score-num {
    color: #ef4444;
  }
  .band-high .score-circle {
    border-color: #f97316;
    background: rgba(249, 115, 22, 0.1);
  }
  .band-high .score-num {
    color: #f97316;
  }
  .band-moderate .score-circle {
    border-color: #eab308;
    background: rgba(234, 179, 8, 0.1);
  }
  .band-moderate .score-num {
    color: #eab308;
  }
  .band-lowmod .score-circle {
    border-color: #60a5fa;
    background: rgba(96, 165, 250, 0.1);
  }
  .band-lowmod .score-num {
    color: #60a5fa;
  }
  .band-strong .score-circle {
    border-color: var(--acc);
    background: rgba(52, 211, 153, 0.1);
  }
  .band-strong .score-num {
    color: var(--acc);
  }
  .prelim-bullets {
    background: var(--bg2);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 12px;
    padding: 24px;
    margin: 24px 0;
  }
  .prelim-bullets h2 {
    font-size: 0.9rem;
    color: var(--white);
    margin-bottom: 14px;
  }
  .bullet {
    display: flex;
    gap: 10px;
    margin-bottom: 10px;
    font-size: 0.86rem;
    color: var(--txt2);
  }
  .bullet-icon {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 1px;
    font-size: 0.7rem;
    font-weight: 800;
  }
  .bi-warn {
    background: rgba(249, 115, 22, 0.15);
    color: #f97316;
  }
  .bi-ok {
    background: rgba(52, 211, 153, 0.15);
    color: var(--acc);
  }
  .gate-card {
    background: var(--bg2);
    border: 1px solid rgba(52, 211, 153, 0.2);
    border-radius: 16px;
    padding: 32px;
    margin-top: 24px;
    text-align: center;
  }
  .gate-card h2 {
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--white);
    margin-bottom: 8px;
  }
  .gate-card p {
    font-size: 0.88rem;
    color: var(--txt2);
    margin-bottom: 20px;
  }
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
    text-align: left;
    margin-bottom: 14px;
  }
  .form-group label {
    font-size: 0.8rem;
    color: var(--txt2);
    font-weight: 600;
  }
  .form-group input {
    background: var(--bg3);
    border: 1.5px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    padding: 10px 14px;
    font-size: 0.9rem;
    color: var(--white);
    font-family: var(--sans);
    transition: border 0.2s;
  }
  .form-group input:focus {
    outline: none;
    border-color: var(--acc2);
  }
  .form-group input::placeholder {
    color: var(--txt3);
  }
  .btn-submit {
    display: block;
    width: 100%;
    padding: 13px;
    border: none;
    border-radius: 8px;
    background: var(--accdark);
    color: #fff;
    font-size: 0.9rem;
    font-weight: 700;
    cursor: pointer;
    font-family: var(--sans);
    transition: background 0.2s;
  }
  .btn-submit:hover {
    background: var(--acc2);
  }
  .btn-submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .form-note {
    font-size: 0.74rem;
    color: var(--txt3);
    margin-top: 8px;
    text-align: center;
  }
  #full-report {
    display: none;
  }
  #full-report.visible {
    display: block;
  }
  .report-section {
    margin-bottom: 28px;
  }
  .report-section h3 {
    font-size: 1rem;
    font-weight: 800;
    color: var(--white);
    margin-bottom: 12px;
    padding-bottom: 6px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }
  .reco-item {
    display: flex;
    gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  }
  .reco-item:last-child {
    border-bottom: none;
  }
  .reco-priority {
    font-family: var(--mono);
    font-size: 0.6rem;
    font-weight: 700;
    padding: 3px 8px;
    border-radius: 4px;
    flex-shrink: 0;
    align-self: flex-start;
    margin-top: 2px;
    letter-spacing: 0.05em;
  }
  .p-critical {
    background: rgba(239, 68, 68, 0.15);
    color: #ef4444;
  }
  .p-high {
    background: rgba(249, 115, 22, 0.15);
    color: #f97316;
  }
  .p-medium {
    background: rgba(234, 179, 8, 0.15);
    color: #eab308;
  }
  .p-low {
    background: rgba(52, 211, 153, 0.15);
    color: var(--acc);
  }
  .reco-text {
    font-size: 0.86rem;
    color: var(--txt2);
  }
  .reco-text strong {
    color: var(--white);
    display: block;
    margin-bottom: 2px;
    font-size: 0.88rem;
  }
  .cta-report {
    background: linear-gradient(135deg, rgba(52, 211, 153, 0.1), rgba(5, 150, 105, 0.05));
    border: 1px solid rgba(52, 211, 153, 0.25);
    border-radius: 12px;
    padding: 28px;
    margin-top: 32px;
    text-align: center;
  }
  .cta-report h3 {
    color: var(--white);
    margin-bottom: 8px;
    font-size: 1.1rem;
  }
  .cta-report p {
    color: var(--txt2);
    font-size: 0.86rem;
    margin-bottom: 18px;
  }
