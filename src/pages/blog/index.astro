---
/**
 * Blog listing page - shows all blog posts sorted by date.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import TagFilter from '../../components/TagFilter.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.datePublished).getTime() - new Date(a.data.datePublished).getTime(),
);

const allTags = [...new Set(posts.flatMap((p) => p.data.tags || []))].sort();
---

<BaseLayout
  title="Cybersecurity Blog | imizicyber"
  description="Practical cybersecurity guides for East African banks, fintechs, and enterprises. Penetration testing, compliance, and security best practices."
  keywords="cybersecurity blog, penetration testing blog, cybersecurity Rwanda, infosec East Africa"
  canonicalUrl="/blog/"
  ogTitle="Cybersecurity Blog | imizicyber"
  ogDescription="Practical cybersecurity guides for East African banks, fintechs, and enterprises."
>
  <main id="main">
    <section style="padding:100px 0 60px">
      <div class="w" style="max-width:920px">
        <h1 class="blog-heading">Blog</h1>
        <p class="blog-sub">Practical cybersecurity guidance for East African organisations.</p>
        <TagFilter tags={allTags} />
        <div class="blog-grid">
          {
            posts.map((post) => (
              <div class="blog-card-wrapper" data-tags={post.data.tags?.join(',') || ''}>
                <BlogCard
                  title={post.data.headline}
                  description={post.data.cardDescription}
                  href={`/blog/${post.id}/`}
                  date={post.data.cardDate}
                  readTime={post.data.readTime}
                  featured={post.data.featured}
                  tags={post.data.tags}
                />
              </div>
            ))
          }
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .blog-heading {
    font-size: clamp(1.6rem, 3.5vw, 2.2rem);
    font-weight: 800;
    letter-spacing: -1px;
    color: var(--white);
    margin-bottom: 8px;
  }
  .blog-sub {
    color: var(--txt2);
    font-size: 0.92rem;
    margin-bottom: 32px;
  }
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
  }
  .blog-grid :global(.blog-card-wrapper) {
    display: block;
  }
  .blog-grid :global(.blog-card-wrapper) :global(.blog-card) {
    height: 100%;
  }
</style>
